---
import Newsletter from '../layouts/Newsletter.astro';
import NewsletterContent from '../components/NewsletterContent.astro';
import TodayFirst from '../components/themes/TodayFirst.astro';
import Newsstand from '../components/themes/Newsstand.astro';
import Pocket from '../components/themes/Pocket.astro';
import config from '../data/config.json';
import weeksIndex from '../data/weeks/weeks-index.json';

export async function getStaticPaths() {
  const weeksIndex = (await import('../data/weeks/weeks-index.json')).default;
  return weeksIndex.map((date: string) => ({
    params: { week: date },
  }));
}

const { week } = Astro.params;
const weekData = (await import(`../data/weeks/${week}.json`)).default;
const issueNumber = weeksIndex.length - weeksIndex.indexOf(week!); // 1-based, oldest = 1

const labelsEn = config.labels.en;
---

<Newsletter title={`${labelsEn.title} — ${labelsEn.subtitle}`} date={weekData.date}>
  <div class="nl-theme" data-variant="A">
    <TodayFirst weekData={weekData} currentDate={week!} allWeeks={weeksIndex} issueNumber={issueNumber} />
  </div>
  <div class="nl-theme" data-variant="B">
    <Newsstand weekData={weekData} currentDate={week!} allWeeks={weeksIndex} issueNumber={issueNumber} />
  </div>
  <div class="nl-theme" data-variant="C">
    <Pocket weekData={weekData} currentDate={week!} allWeeks={weeksIndex} issueNumber={issueNumber} />
  </div>
  <div class="nl-theme" data-variant="classic">
    <NewsletterContent weekData={weekData} currentDate={week!} allWeeks={weeksIndex} />
  </div>
</Newsletter>
