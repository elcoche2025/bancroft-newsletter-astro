---
import Newsletter from '../layouts/Newsletter.astro';
import config from '../data/config.json';
import calendar from '../data/calendar.json';
import weekData from '../data/weeks/2026-03-16.json';
import {
  textToHTML, formatDate, formatDateShort, formatDateRange,
  getDayName, getSubjectIcon, getSpecialForDay, getSubjectTranslation,
  getSchoolYearProgress, getUpcomingDates,
  type Lang
} from '../lib/utils';

const date = weekData.date;
const season = weekData.season || 'spring';
const logo = config.seasonLogos[season as keyof typeof config.seasonLogos] || config.seasonLogos.default;
const labelsEn = config.labels.en;
const labelsEs = config.labels.es;

// School year progress
const progress = getSchoolYearProgress(date);
const upcomingEn = getUpcomingDates(date, 'en');
const upcomingEs = getUpcomingDates(date, 'es');

// Specials data for each classroom
const dayKeys = ['monday', 'tuesday', 'wednesday', 'thursday', 'friday'] as const;
const specials = weekData.specials as Record<string, string>;

// Reminder dates
function parseReminderDate(dateStr: string) {
  const d = new Date(dateStr + 'T12:00:00');
  return {
    month: d.toLocaleDateString('en-US', { month: 'short' }).toUpperCase(),
    monthEs: d.toLocaleDateString('es-US', { month: 'short' }).toUpperCase(),
    day: d.getDate()
  };
}
---

<Newsletter title={`${labelsEn.title} — ${labelsEn.subtitle}`} date={date}>
  <div class="page-wrapper">

    <!-- HEADER -->
    <header class="site-header">
      <div class="header-controls">
        <button class="lang-btn active" data-set-lang="en">English</button>
        <button class="lang-btn" data-set-lang="es">Español</button>
        <button id="dark-toggle" aria-label="Toggle dark mode">🌙</button>
      </div>

      {logo && <img src={`/${logo}`} alt="Bancroft ES" class="site-logo" />}

      <h1 class="site-title" data-en={labelsEn.title} data-es={labelsEs.title}>{labelsEn.title}</h1>
      <p class="site-subtitle" data-en={labelsEn.subtitle} data-es={labelsEs.subtitle}>{labelsEn.subtitle}</p>
      <p class="site-date" data-en={`${labelsEn.weekOf} ${formatDate(date, 'en')}`} data-es={`${labelsEs.weekOf} ${formatDate(date, 'es')}`}>
        {labelsEn.weekOf} {formatDate(date, 'en')}
      </p>
    </header>

    <!-- QUICK LINKS -->
    <nav class="quick-links">
      {config.quickLinks.map(link => (
        <a class="quick-link" href={link.url} target="_blank" rel="noopener">
          <span class="quick-link-icon">{link.icon}</span>
          <span data-en={link.en} data-es={link.es}>{link.en}</span>
        </a>
      ))}
    </nav>

    <!-- DASHBOARD -->
    <div class="dashboard section visible">
      <div class="dashboard-heading" data-en={labelsEn.dashboardHeading} data-es={labelsEs.dashboardHeading}>
        {labelsEn.dashboardHeading}
      </div>
      <div class="dashboard-stats">
        <div class="dashboard-stat">
          <div class="dashboard-stat-value">{progress.weekNumber}/{progress.totalWeeks}</div>
          <div class="dashboard-stat-label" data-en="Week" data-es="Semana">Week</div>
        </div>
        <div class="dashboard-stat">
          <div class="dashboard-stat-value">{progress.remaining}</div>
          <div class="dashboard-stat-label" data-en={labelsEn.schoolDaysLeft} data-es={labelsEs.schoolDaysLeft}>
            {labelsEn.schoolDaysLeft}
          </div>
        </div>
      </div>
      <div class="progress-bar-track">
        <div class="progress-bar-fill" style={`width: ${progress.percent}%`}></div>
      </div>

      <div class="dashboard-upcoming-title" data-en={labelsEn.upcomingDates} data-es={labelsEs.upcomingDates}>
        {labelsEn.upcomingDates}
      </div>
      <ul class="upcoming-list" data-lang-en>
        {upcomingEn.map(item => (
          <li class="upcoming-item">
            <span class="upcoming-date">{formatDateRange(item.startDate, item.endDate, 'en')}</span>
            <span class="upcoming-label">{item.label}</span>
            <span class="upcoming-badge">{calendar.typeLabels.en[item.type as keyof typeof calendar.typeLabels.en] || item.type}</span>
          </li>
        ))}
      </ul>
      <ul class="upcoming-list" data-lang-es style="display:none">
        {upcomingEs.map(item => (
          <li class="upcoming-item">
            <span class="upcoming-date">{formatDateRange(item.startDate, item.endDate, 'es')}</span>
            <span class="upcoming-label">{item.label}</span>
            <span class="upcoming-badge">{calendar.typeLabels.es[item.type as keyof typeof calendar.typeLabels.es] || item.type}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- CLASSROOM SELECTOR -->
    <div class="classroom-selector">
      {config.classrooms.map(name => {
        const flag = config.classroomFlags[name as keyof typeof config.classroomFlags];
        const isImg = flag?.startsWith('img:');
        return (
          <button class="classroom-btn" data-classroom={name}>
            {isImg ? <img src={`/${flag.slice(4)}`} alt={name} /> : <span>{flag}</span>}
            {name}
          </button>
        );
      })}
      <button id="show-all-specials" class="classroom-btn" style="font-style: italic; opacity: 0.7;" data-en="Show All" data-es="Ver Todos">Show All</button>
    </div>

    <!-- WELCOME -->
    <section class="section section--welcome">
      <span class="section-icon">👋</span>
      <h2 class="section-heading" data-en={labelsEn.welcomeHeading} data-es={labelsEs.welcomeHeading}>
        {labelsEn.welcomeHeading}
      </h2>
      <div class="section-body">
        <p data-en={weekData.welcome.en} data-es={weekData.welcome.es} set:html={weekData.welcome.en} />
      </div>
    </section>

    <!-- MATH -->
    <section class="section section--math">
      <span class="section-icon">🔢</span>
      <h2 class="section-heading" data-en={labelsEn.mathHeading} data-es={labelsEs.mathHeading}>
        {labelsEn.mathHeading}
      </h2>
      <div class="section-body" data-lang-en>
        <p set:html={textToHTML(weekData.math.en)} />
      </div>
      <div class="section-body" data-lang-es style="display:none">
        <p set:html={textToHTML(weekData.math.es)} />
      </div>
      {weekData.mathDetails && (
        <div class="math-details">
          <div class="math-detail-row" data-lang-en>
            <span class="math-detail-label">{labelsEn.mathDetailsModule}</span>
            <span class="math-detail-value">{weekData.mathDetails.module.en}</span>
          </div>
          <div class="math-detail-row" data-lang-en>
            <span class="math-detail-label">{labelsEn.mathDetailsTopic}</span>
            <span class="math-detail-value">{weekData.mathDetails.topic.en}</span>
          </div>
          <div class="math-detail-row" data-lang-en>
            <span class="math-detail-label">{labelsEn.mathDetailsLesson}</span>
            <span class="math-detail-value">{weekData.mathDetails.lesson.en}</span>
          </div>
          <div class="math-detail-row" data-lang-es style="display:none">
            <span class="math-detail-label">{labelsEs.mathDetailsModule}</span>
            <span class="math-detail-value">{weekData.mathDetails.module.es}</span>
          </div>
          <div class="math-detail-row" data-lang-es style="display:none">
            <span class="math-detail-label">{labelsEs.mathDetailsTopic}</span>
            <span class="math-detail-value">{weekData.mathDetails.topic.es}</span>
          </div>
          <div class="math-detail-row" data-lang-es style="display:none">
            <span class="math-detail-label">{labelsEs.mathDetailsLesson}</span>
            <span class="math-detail-value">{weekData.mathDetails.lesson.es}</span>
          </div>
        </div>
      )}
    </section>

    <!-- LITERACY -->
    <section class="section section--literacy">
      <span class="section-icon">📖</span>
      <h2 class="section-heading" data-en={labelsEn.literacyHeading} data-es={labelsEs.literacyHeading}>
        {labelsEn.literacyHeading}
      </h2>
      <div class="section-body" data-lang-en>
        <p set:html={textToHTML(weekData.literacy.en)} />
      </div>
      <div class="section-body" data-lang-es style="display:none">
        <p set:html={textToHTML(weekData.literacy.es)} />
      </div>
    </section>

    <!-- SPECIALS — Per-classroom (shown when classroom selected) -->
    <section class="section section--specials specials-personal hidden">
      <span class="section-icon">🎨</span>
      <h2 class="section-heading" data-en={labelsEn.mySpecialsHeading} data-es={labelsEs.mySpecialsHeading}>
        {labelsEn.mySpecialsHeading}
      </h2>
      {config.classrooms.map(classroom => (
        <div class="specials-card" data-classroom={classroom} style="display:none">
          <div class="specials-week-grid">
            {dayKeys.map((day, i) => {
              const letter = specials[day];
              const subject = getSpecialForDay(classroom, letter);
              const icon = getSubjectIcon(subject);
              const translation = getSubjectTranslation(subject);
              return (
                <div class="specials-day-card" data-weather-day={i}>
                  <div class="specials-day-name" data-en={config.labels.en.days[i]} data-es={config.labels.es.days[i]}>
                    {config.labels.en.days[i]}
                  </div>
                  <div class="weather-slot"></div>
                  <span class="specials-day-icon">{icon}</span>
                  <div class="specials-day-subject" data-en={subject} data-es={translation}>{subject}</div>
                  <div class="specials-day-letter">Day {letter}</div>
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </section>

    <!-- SPECIALS — All classrooms table (shown by default) -->
    <section class="section section--specials specials-all">
      <span class="section-icon">🎨</span>
      <h2 class="section-heading" data-en={labelsEn.specialsHeading} data-es={labelsEs.specialsHeading}>
        {labelsEn.specialsHeading}
      </h2>
      <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: separate; border-spacing: 0; font-size: 0.85rem;">
          <thead>
            <tr>
              <th style="text-align: left; padding: 10px 12px; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.06em; border-bottom: 2px solid var(--specials-border);"></th>
              {dayKeys.map((day, i) => (
                <th style="text-align: center; padding: 10px 8px; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.06em; border-bottom: 2px solid var(--specials-border);" data-weather-day={i}>
                  <span data-en={config.labels.en.days[i]} data-es={config.labels.es.days[i]}>{config.labels.en.days[i]}</span>
                  <br /><span style="color: var(--text-light); font-weight: 400;">Day {specials[day]}</span>
                  <div class="weather-slot"></div>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {config.classrooms.map(classroom => (
              <tr>
                <td style="padding: 10px 12px; font-weight: 700; white-space: nowrap; border-bottom: 1px solid var(--border-light); color: var(--text);">{classroom}</td>
                {dayKeys.map(day => {
                  const letter = specials[day];
                  const subject = getSpecialForDay(classroom, letter);
                  const icon = getSubjectIcon(subject);
                  const translation = getSubjectTranslation(subject);
                  return (
                    <td style="text-align: center; padding: 10px 8px; border-bottom: 1px solid var(--border-light);">
                      <span style="font-size: 1.1rem;">{icon}</span><br />
                      <span style="font-size: 0.78rem; font-weight: 500;" data-en={subject} data-es={translation}>{subject}</span>
                    </td>
                  );
                })}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- ROARS -->
    <section class="section section--roars">
      <span class="section-icon">🐯</span>
      <h2 class="section-heading" data-en={labelsEn.roarsHeading} data-es={labelsEs.roarsHeading}>
        {labelsEn.roarsHeading}
      </h2>
      <p class="section-body" style="margin-bottom: 12px; font-size: 0.88rem; color: var(--text-muted);"
        data-en="Congratulations to this week's ROARS students for showing outstanding character!"
        data-es="¡Felicitaciones a los estudiantes ROARS de esta semana por demostrar un carácter excepcional!">
        Congratulations to this week's ROARS students for showing outstanding character!
      </p>
      <div class="roars-grid">
        {config.classrooms.map(classroom => {
          const student = weekData.roars[classroom as keyof typeof weekData.roars];
          return student ? (
            <div class="roars-card">
              <div class="roars-classroom">{classroom}</div>
              <div class="roars-student">{student}</div>
              <span class="roars-trophy">⭐</span>
            </div>
          ) : null;
        })}
      </div>
    </section>

    <!-- REMINDERS -->
    {weekData.reminders && weekData.reminders.length > 0 && (
      <section class="section section--reminders">
        <span class="section-icon">📌</span>
        <h2 class="section-heading" data-en={labelsEn.remindersHeading} data-es={labelsEs.remindersHeading}>
          {labelsEn.remindersHeading}
        </h2>
        <div class="reminder-list">
          {weekData.reminders.map(reminder => {
            const rd = parseReminderDate(reminder.date);
            return (
              <div class="reminder-card">
                <div class="reminder-date-badge">
                  <span class="reminder-date-month" data-en={rd.month} data-es={rd.monthEs}>{rd.month}</span>
                  <span class="reminder-date-day">{rd.day}</span>
                </div>
                <div class="reminder-content" data-lang-en set:html={reminder.en} />
                <div class="reminder-content" data-lang-es style="display:none" set:html={reminder.es} />
              </div>
            );
          })}
        </div>
      </section>
    )}

    <!-- ASK YOUR CHILD -->
    {weekData.askYourChild && weekData.askYourChild.length > 0 && (
      <section class="section section--ask">
        <span class="section-icon">💬</span>
        <h2 class="section-heading" data-en={labelsEn.askHeading} data-es={labelsEs.askHeading}>
          {labelsEn.askHeading}
        </h2>
        <div class="ask-list">
          {weekData.askYourChild.map(item => (
            <div class="ask-item" data-en={item.en} data-es={item.es}>{item.en}</div>
          ))}
        </div>
      </section>
    )}

    <!-- VOCABULARY -->
    {weekData.vocabulary && weekData.vocabulary.en.length > 0 && (
      <section class="section section--vocab">
        <span class="section-icon">📝</span>
        <h2 class="section-heading" data-en={labelsEn.vocabHeading} data-es={labelsEs.vocabHeading}>
          {labelsEn.vocabHeading}
        </h2>
        <div class="vocab-pills" data-lang-en>
          {weekData.vocabulary.en.map(word => (
            <span class="vocab-pill">{word}</span>
          ))}
        </div>
        <div class="vocab-pills" data-lang-es style="display:none">
          {weekData.vocabulary.es.map(word => (
            <span class="vocab-pill">{word}</span>
          ))}
        </div>
      </section>
    )}

    <!-- BOOKS -->
    {weekData.books && weekData.books.length > 0 && (
      <section class="section section--books">
        <span class="section-icon">📚</span>
        <h2 class="section-heading" data-en={labelsEn.booksHeading} data-es={labelsEs.booksHeading}>
          {labelsEn.booksHeading}
        </h2>
        <div class="books-list">
          {weekData.books.map(book => (
            <div class="book-card">
              <span class="book-icon">📕</span>
              <div>
                <div class="book-title" data-en={book.title.en} data-es={book.title.es}>{book.title.en}</div>
                <div class="book-author" data-en={`by ${book.author}`} data-es={`por ${book.author}`}>by {book.author}</div>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- FOOTER -->
    <footer class="site-footer">
      <p data-en="Bancroft Elementary School — First Grade" data-es="Escuela Primaria Bancroft — Primer Grado">
        Bancroft Elementary School — First Grade
      </p>
    </footer>

  </div>
</Newsletter>

<script>
  // Fix active state on lang buttons
  document.addEventListener('DOMContentLoaded', () => {
    function updateLangBtns() {
      const lang = document.documentElement.getAttribute('data-lang');
      document.querySelectorAll('.lang-btn').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.setLang === lang);
      });
    }

    const observer = new MutationObserver(updateLangBtns);
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-lang'] });
    updateLangBtns();
  });

  // Weather — fetch from Open-Meteo for current week only
  (async function loadWeather() {
    const WEEK_DATE = '2026-03-16';
    const now = new Date();
    const weekStart = new Date(WEEK_DATE + 'T00:00:00');
    const weekEnd = new Date(weekStart);
    weekEnd.setDate(weekEnd.getDate() + 4); // Mon–Fri

    // Only fetch weather if this is roughly the current week (within 7 days)
    const diffDays = Math.abs((now.getTime() - weekStart.getTime()) / (1000 * 60 * 60 * 24));
    if (diffDays > 10) return;

    // Bancroft ES coordinates (Washington DC)
    const lat = 38.9283;
    const lon = -77.0365;
    const startDate = WEEK_DATE;
    const endParts = weekEnd.toISOString().split('T')[0];

    try {
      const url = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&daily=temperature_2m_max,temperature_2m_min,precipitation_probability_max,weathercode&temperature_unit=fahrenheit&timezone=America/New_York&start_date=${startDate}&end_date=${endParts}`;
      const resp = await fetch(url);
      if (!resp.ok) return;
      const data = await resp.json();

      const weatherCodes = {
        0: '☀️', 1: '🌤️', 2: '⛅', 3: '☁️',
        45: '🌫️', 48: '🌫️',
        51: '🌦️', 53: '🌧️', 55: '🌧️',
        61: '🌧️', 63: '🌧️', 65: '🌧️',
        71: '🌨️', 73: '🌨️', 75: '🌨️',
        80: '🌦️', 81: '🌧️', 82: '🌧️',
        95: '⛈️', 96: '⛈️', 99: '⛈️',
      };

      const daily = data.daily;
      if (!daily || !daily.time) return;

      for (let i = 0; i < daily.time.length && i < 5; i++) {
        const high = Math.round(daily.temperature_2m_max[i]);
        const low = Math.round(daily.temperature_2m_min[i]);
        const precip = daily.precipitation_probability_max[i];
        const code = daily.weathercode[i];
        const icon = weatherCodes[code] || '🌡️';

        const html = `
          <span class="weather-icon">${icon}</span>
          <span class="weather-temps">${high}°/${low}°</span>
          ${precip > 20 ? `<span class="weather-rain">💧${precip}%</span>` : ''}
        `;

        document.querySelectorAll(`[data-weather-day="${i}"] .weather-slot`).forEach(slot => {
          slot.innerHTML = html;
        });
      }
    } catch (e) {
      // Weather is non-critical, fail silently
    }
  })();
</script>
