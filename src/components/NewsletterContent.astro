<script define:vars={{ weekDate: date, calendarData: calendar }}>
  // === LIVE DASHBOARD: recompute remaining school days using today's real date ===
  // Mirrors the countWeekdays logic in the original script.js so the Astro build
  // matches the live site even though pages are statically prerendered.
  (function updateLiveDashboard() {
    try {
      const parseDate = (s) => new Date(s + 'T12:00:00');
      const formatISO = (d) => {
        const y = d.getFullYear();
        const m = String(d.getMonth() + 1).padStart(2, '0');
        const day = String(d.getDate()).padStart(2, '0');
        return `${y}-${m}-${day}`;
      };

      const firstDay = parseDate(calendarData.firstDay);
      const lastDay = parseDate(calendarData.lastDay);

      // Collect no-school dates (individual dates + break ranges)
      const noSchool = new Set();
      (calendarData.dates || []).forEach(d => noSchool.add(d.date));
      (calendarData.breaks || []).forEach(br => {
        const d = parseDate(br.start);
        const end = parseDate(br.end);
        while (d <= end) {
          noSchool.add(formatISO(d));
          d.setDate(d.getDate() + 1);
        }
      });

      const countWeekdays = (start, end) => {
        let count = 0;
        const d = new Date(start);
        while (d <= end) {
          const dow = d.getDay();
          if (dow >= 1 && dow <= 5 && !noSchool.has(formatISO(d))) count++;
          d.setDate(d.getDate() + 1);
        }
        return count;
      };

      const today = new Date();
      today.setHours(0, 0, 0, 0);
      const effectiveToday = today > lastDay ? lastDay : today < firstDay ? firstDay : today;

      const totalSchoolDays = countWeekdays(firstDay, lastDay);
      const elapsed = countWeekdays(firstDay, effectiveToday);
      const remaining = Math.max(0, totalSchoolDays - elapsed);
      const percent = Math.min(100, Math.round((elapsed / totalSchoolDays) * 100));

      const daysEl = document.getElementById('dashboard-days-remaining');
      if (daysEl) daysEl.textContent = String(remaining);
      const fillEl = document.getElementById('dashboard-progress-fill');
      if (fillEl) fillEl.style.width = percent + '%';
    } catch (err) {
      console.error('Live dashboard update failed:', err);
    }
  })();

  // Fix active state on lang buttons
  document.addEventListener('DOMContentLoaded', () => {
    function updateLangBtns() {
      const lang = document.documentElement.getAttribute('data-lang');
      document.querySelectorAll('.lang-btn').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.setLang === lang);
      });
    }

    const observer = new MutationObserver(updateLangBtns);
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-lang'] });
    updateLangBtns();

    // === ACCORDION (mobile) ===
    const isMobile = () => window.matchMedia('(max-width: 700px)').matches;

    // Collapse all sections on mobile by default
    function initAccordion() {
      document.querySelectorAll('.section[data-section]').forEach(section => {
        if (isMobile()) {
          section.classList.add('collapsed');
        } else {
          section.classList.remove('collapsed');
        }
      });
    }

    initAccordion();
    window.addEventListener('resize', () => {
      // When switching from mobile to desktop, expand all
      if (!isMobile()) {
        document.querySelectorAll('.section.collapsed').forEach(s => s.classList.remove('collapsed'));
      }
    });

    // Click heading to toggle
    document.querySelectorAll('[data-accordion]').forEach(header => {
      header.addEventListener('click', () => {
        if (!isMobile()) return;
        const section = header.closest('.section');
        if (!section) return;
        section.classList.toggle('collapsed');
      });
    });

    // Jump-to: on mobile, expand the target section and scroll to it
    document.querySelectorAll('.jump-to-link').forEach(link => {
      link.addEventListener('click', (e) => {
        const targetId = link.getAttribute('data-jump-target');
        const target = document.getElementById(targetId);
        if (!target) return;

        if (isMobile()) {
          e.preventDefault();
          // Collapse all others, expand target
          document.querySelectorAll('.section[data-section]').forEach(s => {
            if (s.id === targetId) {
              s.classList.remove('collapsed');
            } else {
              s.classList.add('collapsed');
            }
          });
          // Handle specials: if personal is hidden, jump to the all-classrooms one
          if (targetId === 'specials') {
            const personal = document.querySelector('.specials-personal');
            const all = document.querySelector('.specials-all');
            if (personal && personal.classList.contains('hidden') && all) {
              all.classList.remove('collapsed');
              setTimeout(() => all.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
              return;
            }
          }
          setTimeout(() => target.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
        }
      });
    });

    // === SPECIALS REORDERING ===
    // When a classroom is selected, move personal specials to the top (order: -1)
    function reorderSpecials(hasClassroom) {
      const personal = document.querySelector('.specials-personal');
      const allSpecials = document.querySelector('.specials-all');
      if (personal) {
        personal.style.order = hasClassroom ? '-1' : '';
      }
      if (allSpecials) {
        allSpecials.style.order = hasClassroom ? '99' : '';
      }
    }

    // Patch classroom selection to also reorder
    const origSelectClassroom = window.selectClassroom;
    const origShowAll = window.showAllSpecials;

    if (typeof origSelectClassroom === 'function') {
      const _orig = origSelectClassroom;
      window.selectClassroom = function(name) {
        _orig(name);
        reorderSpecials(true);
      };
    }
    if (typeof origShowAll === 'function') {
      const _orig = origShowAll;
      window.showAllSpecials = function() {
        _orig();
        reorderSpecials(false);
      };
    }

    // Apply on load if classroom was saved
    if (localStorage.getItem('nl-classroom')) {
      reorderSpecials(true);
    }

    // === VOCAB FLIP CARDS ===
    document.querySelectorAll('.vocab-pill-flip').forEach(card => {
      card.addEventListener('click', () => card.classList.toggle('flipped'));
    });

    // Update vocab flip card fronts/backs when language changes
    function updateVocabLang() {
      const lang = document.documentElement.getAttribute('data-lang') || 'en';
      document.querySelectorAll('.vocab-pill-flip').forEach(card => {
        const front = card.querySelector('.vocab-pill-front');
        const back = card.querySelector('.vocab-pill-back');
        const forcedFront = card.dataset.frontLang;
        if (front && back && card.dataset.enWord && card.dataset.esWord) {
          if (forcedFront) {
            // Always show this language on front (e.g. SLA always shows Spanish)
            front.textContent = card.dataset.enWord;
            back.textContent = card.dataset.esWord;
          } else {
            front.textContent = lang === 'en' ? card.dataset.enWord : card.dataset.esWord;
            back.textContent = lang === 'en' ? card.dataset.esWord : card.dataset.enWord;
          }
          card.classList.remove('flipped');
        }
      });
      // Update group labels
      document.querySelectorAll('.vocab-group-label[data-en]').forEach(label => {
        label.textContent = lang === 'en' ? label.dataset.en : label.dataset.es;
      });
    }

    const vocabObserver = new MutationObserver(updateVocabLang);
    vocabObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-lang'] });
    updateVocabLang();
  });

  // Weather — fetch from Open-Meteo for current week only
  (async function loadWeather() {
    const WEEK_DATE = weekDate;
    const now = new Date();
    const weekStart = new Date(WEEK_DATE + 'T00:00:00');
    const weekEnd = new Date(weekStart);
    weekEnd.setDate(weekEnd.getDate() + 4); // Mon-Fri

    // Only fetch weather if this is roughly the current week (within 7 days)
    const diffDays = Math.abs((now.getTime() - weekStart.getTime()) / (1000 * 60 * 60 * 24));
    if (diffDays > 10) return;

    // Bancroft ES coordinates (Washington DC)
    const lat = 38.9283;
    const lon = -77.0365;
    const startDate = WEEK_DATE;
    const endParts = weekEnd.toISOString().split('T')[0];

    try {
      const url = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&daily=temperature_2m_max,temperature_2m_min,precipitation_probability_max,weathercode&temperature_unit=fahrenheit&timezone=America/New_York&start_date=${startDate}&end_date=${endParts}`;
      const resp = await fetch(url);
      if (!resp.ok) return;
      const data = await resp.json();

      const weatherCodes = {
        0: '\u2600\uFE0F', 1: '\uD83C\uDF24\uFE0F', 2: '\u26C5', 3: '\u2601\uFE0F',
        45: '\uD83C\uDF2B\uFE0F', 48: '\uD83C\uDF2B\uFE0F',
        51: '\uD83C\uDF26\uFE0F', 53: '\uD83C\uDF27\uFE0F', 55: '\uD83C\uDF27\uFE0F',
        61: '\uD83C\uDF27\uFE0F', 63: '\uD83C\uDF27\uFE0F', 65: '\uD83C\uDF27\uFE0F',
        71: '\uD83C\uDF28\uFE0F', 73: '\uD83C\uDF28\uFE0F', 75: '\uD83C\uDF28\uFE0F',
        80: '\uD83C\uDF26\uFE0F', 81: '\uD83C\uDF27\uFE0F', 82: '\uD83C\uDF27\uFE0F',
        95: '\u26C8\uFE0F', 96: '\u26C8\uFE0F', 99: '\u26C8\uFE0F',
      };

      const daily = data.daily;
      if (!daily || !daily.time) return;

      for (let i = 0; i < daily.time.length && i < 5; i++) {
        const high = Math.round(daily.temperature_2m_max[i]);
        const low = Math.round(daily.temperature_2m_min[i]);
        const precip = daily.precipitation_probability_max[i];
        const code = daily.weathercode[i];
        const icon = weatherCodes[code] || '\uD83C\uDF21\uFE0F';

        const html = `
          <span class="weather-icon">${icon}</span>
          <span class="weather-temps">${high}\u00B0/${low}\u00B0</span>
          ${precip > 20 ? `<span class="weather-rain">\uD83D\uDCA7${precip}%</span>` : ''}
        `;

        document.querySelectorAll(`[data-weather-day="${i}"] .weather-slot`).forEach(slot => {
          slot.innerHTML = html;
        });
      }
    } catch (e) {
      // Weather is non-critical, fail silently
    }
  })();
</script>
