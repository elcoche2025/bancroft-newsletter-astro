---
// Floating theme selector — fixed top-right, opens a popover with 4 theme cards.
// Persists choice to localStorage('nl-theme') and updates <html data-theme>.
// Sits outside the theme components so it's always visible regardless of active theme.
---

<div class="nl-theme-selector" data-nl-selector>
  <button class="nlts-btn" type="button" aria-label="Choose theme" aria-haspopup="true" aria-expanded="false" data-nl-selector-btn>
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/>
      <circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/>
      <circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/>
      <circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/>
      <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.83 0 1.5-.67 1.5-1.5 0-.39-.15-.74-.39-1.01-.23-.26-.38-.61-.38-.99 0-.83.67-1.5 1.5-1.5H16c3.31 0 6-2.69 6-6 0-4.97-4.5-9-10-9z"></path>
    </svg>
    <span class="nlts-btn-dot" aria-hidden="true"></span>
  </button>

  <div class="nlts-popover" role="dialog" aria-label="Newsletter theme" hidden data-nl-selector-popover>
    <div class="nlts-head">
      <span class="nlts-head-title">Newsletter theme</span>
      <button class="nlts-close" type="button" aria-label="Close" data-nl-selector-close>
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <p class="nlts-lede">Pick the look that fits how you read this week. Your choice is remembered on this device.</p>

    <button class="nlts-card is-A" type="button" data-nl-theme="A">
      <span class="nlts-swatch nlts-swatch-A" aria-hidden="true">
        <span class="sw1"></span><span class="sw2"></span><span class="sw3"></span>
      </span>
      <span class="nlts-card-body">
        <span class="nlts-card-name">Today First</span>
        <span class="nlts-card-desc">Refined cream paper, BLUF hierarchy, "Day 158 of 180" milestone, 5 grouped accordions.</span>
      </span>
      <span class="nlts-card-check" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
      </span>
    </button>

    <button class="nlts-card is-B" type="button" data-nl-theme="B">
      <span class="nlts-swatch nlts-swatch-B" aria-hidden="true">
        <span class="sw-mast"></span>
        <span class="sw-rule"></span>
        <span class="sw-body"></span>
      </span>
      <span class="nlts-card-body">
        <span class="nlts-card-name">Newsstand</span>
        <span class="nlts-card-desc">Editorial magazine: big Fraunces masthead, "In This Issue," ROARS as the cover story.</span>
      </span>
      <span class="nlts-card-check" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
      </span>
    </button>

    <button class="nlts-card is-C" type="button" data-nl-theme="C">
      <span class="nlts-swatch nlts-swatch-C" aria-hidden="true">
        <span class="sw-sticky"></span>
        <span class="sw-status"></span>
        <span class="sw-stack"></span>
        <span class="sw-stack"></span>
      </span>
      <span class="nlts-card-body">
        <span class="nlts-card-name">Pocket</span>
        <span class="nlts-card-desc">App-feel: sticky header, urgent status bar, dense card stack with one-line peeks.</span>
      </span>
      <span class="nlts-card-check" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
      </span>
    </button>

    <div class="nlts-divider"><span>Or, the old look</span></div>

    <button class="nlts-card is-classic" type="button" data-nl-theme="classic">
      <span class="nlts-swatch nlts-swatch-classic" aria-hidden="true">
        <span class="sw-dash"></span>
        <span class="sw-sec"></span>
        <span class="sw-sec"></span>
      </span>
      <span class="nlts-card-body">
        <span class="nlts-card-name">Classic</span>
        <span class="nlts-card-desc">The original Bancroft layout — exactly as it's been for the past month.</span>
      </span>
      <span class="nlts-card-check" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
      </span>
    </button>
  </div>
</div>

<style is:global>
  .nl-theme-selector {
    position: fixed;
    top: 14px;
    right: 14px;
    z-index: 1000;
    font-family: "DM Sans", system-ui, sans-serif;
  }
  /* On mobile, the per-theme language toggle sits in the top-right (themes B & C)
     or the top of the page chrome (themes A, Classic). Move our floating selector
     to the bottom-right corner so it never covers the EN/ES pill. */
  @media (max-width: 700px) {
    .nl-theme-selector {
      top: auto;
      right: 14px;
      bottom: calc(14px + env(safe-area-inset-bottom, 0px));
    }
    /* Popover should open UPWARD on mobile since the button is at the bottom. */
    .nlts-popover {
      top: auto;
      bottom: 46px;
      transform-origin: bottom right;
    }
    @keyframes nlts-pop-in {
      from { opacity: 0; transform: scale(0.96) translateY(6px); }
      to   { opacity: 1; transform: scale(1) translateY(0); }
    }
  }
  .nlts-btn {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: #ffffff;
    border: 1px solid rgba(20, 16, 8, 0.12);
    box-shadow: 0 2px 8px rgba(20, 16, 8, 0.10), 0 1px 2px rgba(20, 16, 8, 0.06);
    color: #1a1a2e;
    cursor: pointer;
    display: grid;
    place-items: center;
    position: relative;
    transition: transform 0.15s ease, box-shadow 0.2s ease;
    padding: 0;
  }
  .nlts-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(20, 16, 8, 0.14), 0 2px 4px rgba(20, 16, 8, 0.06);
  }
  .nlts-btn:focus-visible {
    outline: 2px solid #6d28d9;
    outline-offset: 2px;
  }
  .nlts-btn-dot {
    position: absolute;
    right: -2px;
    bottom: -2px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid #ffffff;
    background: #c96442;
    box-shadow: 0 1px 2px rgba(20, 16, 8, 0.18);
  }
  html[data-theme="A"]       .nlts-btn-dot { background: #1a1a2e; }
  html[data-theme="B"]       .nlts-btn-dot { background: #b8860b; }
  html[data-theme="C"]       .nlts-btn-dot { background: #6d28d9; }
  html[data-theme="classic"] .nlts-btn-dot { background: #c2410c; }

  .nlts-popover {
    position: absolute;
    top: 46px;
    right: 0;
    width: min(340px, calc(100vw - 28px));
    background: #ffffff;
    border: 1px solid rgba(20, 16, 8, 0.10);
    border-radius: 16px;
    box-shadow: 0 24px 60px rgba(20, 16, 8, 0.18), 0 6px 16px rgba(20, 16, 8, 0.08);
    padding: 14px;
    color: #1a1a2e;
    transform-origin: top right;
    animation: nlts-pop-in 0.18s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .nlts-popover[hidden] { display: none !important; }

  @keyframes nlts-pop-in {
    from { opacity: 0; transform: scale(0.96) translateY(-6px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }

  .nlts-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 6px;
  }
  .nlts-head-title {
    font: 700 0.88rem/1 "Fraunces", Georgia, serif;
    letter-spacing: -0.01em;
  }
  .nlts-close {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: transparent;
    border: 0;
    cursor: pointer;
    display: grid;
    place-items: center;
    color: #5e5e80;
    padding: 0;
  }
  .nlts-close:hover { background: #f6f1e6; color: #1a1a2e; }
  .nlts-lede {
    margin: 0 0 10px;
    font-size: 0.78rem;
    color: #5e5e80;
    line-height: 1.4;
  }

  .nlts-card {
    display: grid;
    grid-template-columns: 44px 1fr 18px;
    gap: 12px;
    width: 100%;
    align-items: center;
    background: #faf8f3;
    border: 1px solid rgba(20, 16, 8, 0.08);
    border-radius: 12px;
    padding: 10px 12px;
    margin-bottom: 6px;
    cursor: pointer;
    text-align: left;
    color: inherit;
    font: inherit;
    transition: background 0.15s ease, border-color 0.15s ease, transform 0.12s ease;
  }
  .nlts-card:last-child { margin-bottom: 0; }
  .nlts-card:hover {
    background: #fff;
    border-color: rgba(20, 16, 8, 0.18);
    transform: translateY(-1px);
  }
  .nlts-card[aria-pressed="true"] {
    background: #fef9ee;
    border-color: #f0d68a;
    box-shadow: 0 0 0 3px rgba(184, 134, 11, 0.10);
  }
  .nlts-card-check { color: transparent; }
  .nlts-card[aria-pressed="true"] .nlts-card-check { color: #b8860b; }

  .nlts-card-name {
    display: block;
    font: 700 0.92rem/1.1 "Fraunces", Georgia, serif;
    letter-spacing: -0.01em;
    margin-bottom: 2px;
  }
  .nlts-card-desc {
    display: block;
    font-size: 0.72rem;
    line-height: 1.35;
    color: #5e5e80;
  }

  /* ===== Swatches ===== */
  .nlts-swatch {
    width: 44px;
    height: 56px;
    border-radius: 6px;
    overflow: hidden;
    position: relative;
    border: 1px solid rgba(20, 16, 8, 0.10);
    display: block;
  }
  /* A — Today First: black hero card on cream */
  .nlts-swatch-A {
    background: #fefcf8;
  }
  .nlts-swatch-A .sw1 {
    position: absolute; left: 4px; right: 4px; top: 4px; height: 16px;
    background: #1a1a2e; border-radius: 4px;
  }
  .nlts-swatch-A .sw2 {
    position: absolute; left: 4px; right: 4px; top: 24px; height: 6px;
    background: linear-gradient(90deg, #2d8a4e 0%, #2563a8 50%, #6d28d9 100%);
    border-radius: 100px;
  }
  .nlts-swatch-A .sw3 {
    position: absolute; left: 4px; right: 4px; bottom: 4px; height: 18px;
    background: #fef2f2; border: 1px solid #fecaca; border-radius: 4px;
  }

  /* B — Newsstand: paper + double-rule masthead */
  .nlts-swatch-B {
    background: #f6f1e6;
  }
  .nlts-swatch-B .sw-mast {
    position: absolute; left: 4px; right: 4px; top: 4px; height: 14px;
    background:
      linear-gradient(#1c1714, #1c1714) 0 100% / 100% 1px no-repeat,
      linear-gradient(#1c1714, #1c1714) 0 calc(100% - 3px) / 100% 1px no-repeat;
    font: 800 8px "Fraunces", serif;
    color: #1c1714;
    text-align: center;
  }
  .nlts-swatch-B .sw-mast::after {
    content: "BANCROFT"; font: 900 7px/14px "Fraunces", serif; color: #1c1714; letter-spacing: -0.02em;
  }
  .nlts-swatch-B .sw-rule {
    position: absolute; left: 4px; right: 4px; top: 22px; height: 1px;
    background: #d8cfb8;
  }
  .nlts-swatch-B .sw-body {
    position: absolute; left: 4px; right: 4px; top: 26px; bottom: 4px;
    background:
      linear-gradient(#1c1714, #1c1714) 0 4px / 100% 1px no-repeat,
      linear-gradient(#1c1714, #1c1714) 0 9px / 60% 1px no-repeat,
      linear-gradient(#1c1714, #1c1714) 0 14px / 100% 1px no-repeat,
      linear-gradient(#1c1714, #1c1714) 0 19px / 75% 1px no-repeat;
    opacity: 0.45;
  }

  /* C — Pocket: sticky bar + status + cards */
  .nlts-swatch-C {
    background: #fefcf8;
  }
  .nlts-swatch-C .sw-sticky {
    position: absolute; left: 0; right: 0; top: 0; height: 14px;
    background: rgba(254, 252, 248, 0.92);
    border-bottom: 1px solid #e8e5dd;
  }
  .nlts-swatch-C .sw-sticky::after {
    content: ""; position: absolute; left: 4px; bottom: 3px; right: 4px; height: 2px;
    background: linear-gradient(90deg, #2d8a4e 0%, #2563a8 50%, #6d28d9 100%);
    border-radius: 100px;
  }
  .nlts-swatch-C .sw-status {
    position: absolute; left: 4px; right: 4px; top: 18px; height: 8px;
    background: #b91c1c; border-radius: 3px;
  }
  .nlts-swatch-C .sw-stack {
    position: absolute; left: 4px; right: 4px; height: 9px;
    background: #fff; border: 1px solid #e8e5dd; border-radius: 4px;
  }
  .nlts-swatch-C .sw-stack:nth-of-type(3) { top: 30px; }
  .nlts-swatch-C .sw-stack:nth-of-type(4) { top: 42px; }

  /* Classic — current dashboard look */
  .nlts-swatch-classic {
    background: #fefcf8;
  }
  .nlts-swatch-classic .sw-dash {
    position: absolute; left: 4px; right: 4px; top: 4px; height: 18px;
    background: #fff; border: 1px solid #e8e5dd; border-radius: 4px;
  }
  .nlts-swatch-classic .sw-dash::after {
    content: ""; position: absolute; left: 4px; right: 4px; bottom: 3px; height: 2px;
    background: linear-gradient(90deg, #2d8a4e, #2563a8, #6d28d9); border-radius: 100px;
  }
  .nlts-swatch-classic .sw-sec {
    position: absolute; left: 4px; right: 4px; height: 11px;
    background: #f0faf0; border: 1px solid #a8dbb8; border-radius: 4px;
  }
  .nlts-swatch-classic .sw-sec:nth-of-type(3) { top: 26px; }
  .nlts-swatch-classic .sw-sec:nth-of-type(4) {
    top: 41px; background: #fff5ed; border-color: #fed7aa;
  }

  .nlts-divider {
    text-align: center;
    margin: 12px 0 8px;
    font-size: 0.7rem;
    color: #9090ad;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    position: relative;
  }
  .nlts-divider::before,
  .nlts-divider::after {
    content: "";
    position: absolute;
    top: 50%;
    width: 28%;
    height: 1px;
    background: #e8e5dd;
  }
  .nlts-divider::before { left: 0; }
  .nlts-divider::after  { right: 0; }

  /* ===== Print: hide the selector ===== */
  @media print {
    .nl-theme-selector { display: none !important; }
  }
</style>

<script is:inline>
  (function () {
    var root = document.documentElement;
    var sel = document.querySelector('[data-nl-selector]');
    if (!sel) return;
    var btn = sel.querySelector('[data-nl-selector-btn]');
    var pop = sel.querySelector('[data-nl-selector-popover]');
    var closeBtn = sel.querySelector('[data-nl-selector-close]');
    var cards = sel.querySelectorAll('[data-nl-theme]');

    function getTheme() {
      var t = root.getAttribute('data-theme') || 'classic';
      if (t !== 'A' && t !== 'B' && t !== 'C' && t !== 'classic') t = 'classic';
      return t;
    }
    function setTheme(t) {
      if (t !== 'A' && t !== 'B' && t !== 'C' && t !== 'classic') return;
      root.setAttribute('data-theme', t);
      try { localStorage.setItem('nl-theme', t); } catch (e) {}
      reflectSelection();
      // Notify themes that they were just shown — gives them a chance to refresh
      // animations or lazy-fetch (e.g. weather) on first reveal.
      window.dispatchEvent(new CustomEvent('nl-theme-change', { detail: { theme: t } }));
    }
    function reflectSelection() {
      var current = getTheme();
      cards.forEach(function (c) {
        var pressed = c.getAttribute('data-nl-theme') === current;
        c.setAttribute('aria-pressed', pressed ? 'true' : 'false');
      });
    }
    function openPop() {
      pop.hidden = false;
      btn.setAttribute('aria-expanded', 'true');
      reflectSelection();
    }
    function closePop() {
      pop.hidden = true;
      btn.setAttribute('aria-expanded', 'false');
    }
    function toggle() {
      if (pop.hidden) openPop(); else closePop();
    }

    btn.addEventListener('click', function (e) {
      e.stopPropagation();
      toggle();
    });
    if (closeBtn) closeBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      closePop();
    });
    cards.forEach(function (c) {
      c.addEventListener('click', function () {
        setTheme(c.getAttribute('data-nl-theme'));
        closePop();
      });
    });
    document.addEventListener('click', function (e) {
      if (pop.hidden) return;
      if (!sel.contains(e.target)) closePop();
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !pop.hidden) closePop();
    });

    reflectSelection();
  })();
</script>
