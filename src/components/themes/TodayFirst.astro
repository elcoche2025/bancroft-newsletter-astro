---
import config from '../../data/config.json';
import calendar from '../../data/calendar.json';
import {
  textToHTML, formatDate, formatDateShort,
  getSubjectIcon, getSpecialForDay, getSubjectTranslation,
  getSchoolYearProgress,
} from '../../lib/utils';

interface Props {
  weekData: any;
  currentDate: string;
  allWeeks: string[];
  issueNumber: number;
}

const { weekData } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const date = weekData.date;
const season = weekData.season || 'spring';
const logo = config.seasonLogos[season as keyof typeof config.seasonLogos] || config.seasonLogos.default;

const labelsEn = config.labels.en;
const labelsEs = config.labels.es;

// School year progress (server-side fallback; client JS will recompute with live date)
const progress = getSchoolYearProgress(date);

// Day keys for specials grid
const dayKeys = ['monday', 'tuesday', 'wednesday', 'thursday', 'friday'] as const;
const dayAbbrsEn = ['M', 'T', 'W', 'Th', 'F'];
const dayAbbrsEs = ['L', 'M', 'Mi', 'J', 'V'];
const specials = weekData.specials as Record<string, string>;

// Reminder date parser
function parseReminderDate(dateStr: string) {
  const d = new Date(dateStr + 'T12:00:00');
  return {
    month: d.toLocaleDateString('en-US', { month: 'short' }).toUpperCase(),
    monthEs: d.toLocaleDateString('es-US', { month: 'short' }).toUpperCase(),
    day: d.getDate(),
  };
}

// Sorted reminders (ascending by date)
const sortedReminders = weekData.reminders
  ? [...weekData.reminders].sort((a: any, b: any) => a.date.localeCompare(b.date))
  : [];

// Vocabulary grouping detection
const hasVocab = weekData.vocabulary && Array.isArray(weekData.vocabulary.en) && weekData.vocabulary.en.length > 0;
const vocabIsGrouped = hasVocab && typeof weekData.vocabulary.en[0] === 'object' && weekData.vocabulary.en[0].words;

// Books
const hasBooks = weekData.books && weekData.books.length > 0;

// Term labels for the trail
const termLabels = ['T1', 'T2', 'T3', 'T4'];
const termPercents = [0, 25, 50, 75];

// Formatted week date for server-side render of Today hero
const weekDateObj = new Date(date + 'T12:00:00');
const weekDayNameEn = weekDateObj.toLocaleDateString('en-US', { weekday: 'long' });
const weekDayNameEs = weekDateObj.toLocaleDateString('es-US', { weekday: 'long' });
const weekMonthDayEn = weekDateObj.toLocaleDateString('en-US', { month: 'long', day: 'numeric' });
const weekMonthDayEs = weekDateObj.toLocaleDateString('es-US', { month: 'long', day: 'numeric' });

// Server-side "today" specials (Monday's letter as fallback)
const mondayLetter = specials['monday'];
const firstClassroom = config.classrooms[0];
const mondaySubject = getSpecialForDay(firstClassroom, mondayLetter);
const mondayIcon = getSubjectIcon(mondaySubject);
const mondaySubjectEs = getSubjectTranslation(mondaySubject);

// First upcoming reminder for "Next Up" fallback
const firstReminder = sortedReminders[0];
let nextUpEnFallback = '';
let nextUpEsFallback = '';
if (firstReminder) {
  // Strip HTML for short display
  const stripped = firstReminder.en.replace(/<[^>]+>/g, '').slice(0, 50);
  const strippedEs = firstReminder.es.replace(/<[^>]+>/g, '').slice(0, 50);
  nextUpEnFallback = stripped;
  nextUpEsFallback = strippedEs;
}

// Ask your child items
const hasAsk = weekData.askYourChild && weekData.askYourChild.length > 0;

// Vocab + ask count for Talk At Home peek
const askCount = hasAsk ? weekData.askYourChild.length : 0;
const vocabWordCount = hasVocab
  ? (vocabIsGrouped
    ? (weekData.vocabulary.en as any[]).reduce((acc: number, g: any) => acc + g.words.length, 0)
    : weekData.vocabulary.en.length)
  : 0;

// Reminder count for badge
const reminderCount = sortedReminders.length;

// Flag helper
function getFlagSrc(classroom: string): string {
  const flag = (config.classroomFlags as Record<string, string>)[classroom];
  if (flag?.startsWith('img:')) return `${base}/${flag.slice(4)}`;
  return '';
}
---

<!-- ================================================================
     THEME A — TODAY FIRST
     Scoped: html[data-theme="A"] — never bleeds into other themes
     ================================================================ -->

<div class="tf-wrap">

  <!-- TOP BAR -->
  <div class="tf-top-bar">
    <div class="tf-lang-toggle" role="tablist" aria-label="Language">
      <button class="lang-btn active tf-lang-btn" data-set-lang="en">English</button>
      <button class="lang-btn tf-lang-btn" data-set-lang="es">Español</button>
    </div>
    <div class="tf-top-icons">
      <button aria-label="Print" title="Print" onclick="window.print()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect></svg>
      </button>
    </div>
  </div>

  <!-- TITLE BLOCK -->
  <div class="tf-title-block">
    {logo && <img src={`${base}/${logo}`} alt="Bancroft ES" />}
    <h1 class="tf-display">
      <span data-en={labelsEn.title} data-es={labelsEs.title}>{labelsEn.title}</span>
    </h1>
    <p class="tf-subtitle">
      <span data-en={labelsEn.subtitle} data-es={labelsEs.subtitle}>{labelsEn.subtitle}</span>
    </p>
    <p class="tf-week-date">
      <span data-en={`${labelsEn.weekOf} ${formatDate(date, 'en')}`} data-es={`${labelsEs.weekOf} ${formatDate(date, 'es')}`}>
        {labelsEn.weekOf} {formatDate(date, 'en')}
      </span>
    </p>
  </div>

  <!-- TODAY CARD (hero) -->
  <section class="tf-today" aria-label="Today at a glance" id="tf-today-card">
    <div class="tf-today-head">
      <div class="tf-today-day" id="tf-today-day-name">
        <span data-en>{weekDayNameEn} <em>{weekMonthDayEn}</em></span>
        <span data-es style="display:none">{weekDayNameEs} <em>{weekMonthDayEs}</em></span>
      </div>
      <div class="tf-today-weather" id="tf-today-weather">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
        <span id="tf-weather-text">--</span>
      </div>
    </div>

    <div class="tf-today-grid">
      <div class="tf-today-cell">
        <div class="tf-today-cell-label">
          <span data-en>Today's Specials</span>
          <span data-es style="display:none">Especiales Hoy</span>
        </div>
        <div class="tf-today-cell-val" id="tf-today-special">
          <span data-en id="tf-today-special-en"><span class="tf-emoji">📅</span> Day {mondayLetter} <span class="tf-pick-hint" style="opacity:.65">· pick your class below</span></span>
          <span data-es style="display:none" id="tf-today-special-es"><span class="tf-emoji">📅</span> Día {mondayLetter} <span class="tf-pick-hint" style="opacity:.65">· elige tu salón abajo</span></span>
        </div>
      </div>
      <div class="tf-today-cell tf-today-cell--next-up">
        <div class="tf-today-cell-label">
          <span data-en>Next Up</span>
          <span data-es style="display:none">Próximo</span>
        </div>
        <div class="tf-today-cell-val" id="tf-today-next-up">
          {firstReminder ? (
            <>
              <span data-en id="tf-next-up-en">{nextUpEnFallback}</span>
              <span data-es style="display:none" id="tf-next-up-es">{nextUpEsFallback}</span>
            </>
          ) : (
            <span style="opacity:.6">—</span>
          )}
        </div>
      </div>
    </div>

    <div class="tf-today-foot">
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
      <span data-en>Dismissal 3:15 pm</span>
      <span data-es style="display:none">Salida 3:15 pm</span>
    </div>
  </section>

  <!-- MILESTONE TRAIL -->
  <div class="tf-trail-card">
    <div class="tf-trail-head">
      <h2 class="tf-display">
        <span data-en>Days of 1st Grade</span>
        <span data-es style="display:none">Días de Primer Grado</span>
      </h2>
      <div class="tf-trail-num">
        <span id="tf-trail-elapsed">{progress.elapsedSchoolDays}</span><em> / {progress.totalSchoolDays}</em>
      </div>
    </div>
    <div class="tf-trail">
      <div class="tf-trail-line"></div>
      <div class="tf-trail-fill" id="tf-trail-fill" style={`width: ${progress.percent}%`}></div>
      {termLabels.map((lbl, i) => (
        <div class={`tf-trail-mark tf-trail-mark--done`} style={`left: ${termPercents[i]}%`}>
          <div class="tf-trail-dot"></div>
          <div class="tf-trail-lbl">{lbl}</div>
        </div>
      ))}
      <div class="tf-trail-mark tf-trail-mark--now" id="tf-trail-now" style={`left: ${progress.percent}%`}>
        <div class="tf-trail-dot"></div>
        <div class="tf-trail-lbl">
          <span data-en>Now</span>
          <span data-es style="display:none">Hoy</span>
        </div>
      </div>
    </div>
    <div class="tf-trail-foot">
      <span>
        <span data-en>Week {progress.weekNumber} of {progress.totalWeeks}</span>
        <span data-es style="display:none">Semana {progress.weekNumber} de {progress.totalWeeks}</span>
      </span>
      <span>
        <strong id="tf-trail-remaining">{progress.remaining}</strong>
        <span data-en> school days remaining</span>
        <span data-es style="display:none"> días escolares restantes</span>
      </span>
    </div>
  </div>

  <!-- CLASSROOM SELECTOR -->
  <div class="tf-room-selector">
    <div class="tf-room-selector-lbl">
      <span>
        <span data-en>Tap your child's classroom</span>
        <span data-es style="display:none">Toca el salón de tu hijo/a</span>
      </span>
      <em id="tf-room-selected-name"></em>
    </div>
    <div class="tf-room-grid">
      {config.classrooms.map((classroom) => {
        const flagSrc = getFlagSrc(classroom);
        return (
          <button class="tf-room-pill" data-tf-classroom={classroom}>
            {flagSrc && <img src={flagSrc} alt="" />}
            {classroom}
          </button>
        );
      })}
    </div>
  </div>

  <!-- QUICK LINKS -->
  <nav class="tf-quick-links" aria-label="Quick links">
    {config.quickLinks.map(link => (
      <a class="tf-quick-link" href={link.url} target="_blank" rel="noopener">
        <span class="tf-quick-link-ic">{link.icon}</span>
        <span data-en={link.en} data-es={link.es}>{link.en}</span>
      </a>
    ))}
  </nav>

  <!-- ============================================================== -->
  <!-- GROUP 1 — REMINDERS                                             -->
  <!-- ============================================================== -->
  {sortedReminders.length > 0 && (
    <details class="tf-group tf-group--action" open>
      <summary class="tf-group-head">
        <div class="tf-group-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="#b91c1c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="17" x2="12" y2="22"></line><path d="M5 17h14l-1.7-3.4A2 2 0 0 1 17 12.6V8a5 5 0 0 0-10 0v4.6c0 .3-.07.6-.21.85L5 17z"></path></svg>
        </div>
        <div class="tf-group-meta">
          <h2 class="tf-display">
            <span data-en>Reminders</span>
            <span data-es style="display:none">Recordatorios</span>
          </h2>
          <div class="tf-group-peek">
            <span data-en>{reminderCount} reminder{reminderCount !== 1 ? 's' : ''}</span>
            <span data-es style="display:none">{reminderCount} recordatorio{reminderCount !== 1 ? 's' : ''}</span>
          </div>
        </div>
        <div class="tf-group-count tf-group-count--action">{reminderCount}</div>
        <span class="tf-chev"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></span>
      </summary>
      <div class="tf-group-body">
        {sortedReminders.map((reminder: any, i: number) => {
          const rd = parseReminderDate(reminder.date);
          const isUrgent = i === 0;
          return (
            <div class={`tf-reminder${isUrgent ? ' tf-reminder--urgent' : ''}`}>
              <div class="tf-reminder-badge">
                <div class="tf-reminder-mo">
                  <span data-en={rd.month} data-es={rd.monthEs}>{rd.month}</span>
                </div>
                <div class="tf-reminder-day">{rd.day}</div>
              </div>
              <div class="tf-reminder-body">
                {isUrgent && (
                  <span class="tf-urgent-tag">
                    <span data-en>This Week</span>
                    <span data-es style="display:none">Esta Semana</span>
                  </span>
                )}
                <span data-lang-en set:html={reminder.en} />
                <span data-lang-es style="display:none" set:html={reminder.es} />
              </div>
            </div>
          );
        })}
      </div>
    </details>
  )}

  <!-- ============================================================== -->
  <!-- GROUP 2 — SPECIALS SCHEDULE                                     -->
  <!-- ============================================================== -->
  <details class="tf-group tf-group--specials" open>
    <summary class="tf-group-head">
      <div class="tf-group-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="#6d28d9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r=".5" fill="#6d28d9"/><circle cx="17.5" cy="10.5" r=".5" fill="#6d28d9"/><circle cx="8.5" cy="7.5" r=".5" fill="#6d28d9"/><circle cx="6.5" cy="12.5" r=".5" fill="#6d28d9"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.83 0 1.5-.67 1.5-1.5 0-.39-.15-.74-.39-1.01-.23-.26-.38-.61-.38-.99 0-.83.67-1.5 1.5-1.5H16c3.31 0 6-2.69 6-6 0-4.97-4.5-9-10-9z"></path></svg>
      </div>
      <div class="tf-group-meta">
        <h2 class="tf-display">
          <span data-en>Specials Schedule</span>
          <span data-es style="display:none">Horario de Especiales</span>
        </h2>
        <div class="tf-group-peek" id="tf-specials-peek">
          <span data-en>Your classroom's week at a glance</span>
          <span data-es style="display:none">La semana de tu salón de un vistazo</span>
        </div>
      </div>
      <span class="tf-chev"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></span>
    </summary>
    <div class="tf-group-body">

      <!-- My Specials card (per-classroom, 5-day) -->
      <div class="tf-my-specials" id="tf-my-specials">
        {config.classrooms.map((classroom) => {
          const flagSrc = getFlagSrc(classroom);
          return (
            <div class="tf-ms-classroom" data-tf-specials-classroom={classroom} style="display:none">
              <div class="tf-ms-head">
                <div class="tf-ms-room-name">
                  {flagSrc && <img src={flagSrc} alt="" />}
                  {classroom}
                </div>
                <div class="tf-micro" style="color: var(--tf-spec-ac)">
                  <span data-en>This Week</span>
                  <span data-es style="display:none">Esta Semana</span>
                </div>
              </div>
              <div class="tf-ms-grid">
                {dayKeys.map((day, di) => {
                  const letter = specials[day];
                  const subject = getSpecialForDay(classroom, letter);
                  const icon = getSubjectIcon(subject);
                  const subjectEs = getSubjectTranslation(subject);
                  const abbrsEn = ['M','T','W','Th','F'];
                  const abbrsEs = ['L','M','Mi','J','V'];
                  return (
                    <div class="tf-ms-day" data-tf-day-index={di} data-weather-day={di}>
                      <div class="tf-ms-dow">
                        <span data-en>{abbrsEn[di]}</span>
                        <span data-es style="display:none">{abbrsEs[di]}</span>
                      </div>
                      <div class="tf-weather-slot"></div>
                      <div class="tf-ms-subj-icon">{icon}</div>
                      <div class="tf-ms-subj">
                        <span data-en>{subject}</span>
                        <span data-es style="display:none">{subjectEs}</span>
                      </div>
                      <div class="tf-ms-letter">{letter}</div>
                    </div>
                  );
                })}
              </div>
            </div>
          );
        })}
      </div>

      <!-- Full grid (all classrooms) -->
      <div class="tf-full-grid">
        <table>
          <thead>
            <tr>
              <th></th>
              {dayKeys.map((day, di) => (
                <th data-weather-day={di}>
                  <span data-en>{dayAbbrsEn[di]}</span>
                  <span data-es style="display:none">{dayAbbrsEs[di]}</span>
                  <span class="tf-full-grid-letter">{specials[day]}</span>
                  <div class="tf-weather-slot"></div>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {config.classrooms.map((classroom) => {
              const flagSrc = getFlagSrc(classroom);
              return (
                <tr data-tf-grid-classroom={classroom}>
                  <td class="tf-full-grid-room">
                    {flagSrc && <img src={flagSrc} alt="" />}
                    {classroom}
                  </td>
                  {dayKeys.map((day) => {
                    const letter = specials[day];
                    const subject = getSpecialForDay(classroom, letter);
                    const icon = getSubjectIcon(subject);
                    const subjectEs = getSubjectTranslation(subject);
                    return (
                      <td>
                        <span class="tf-cell-icon">{icon}</span>
                        <span class="tf-cell-subj">
                          <span data-en>{subject}</span>
                          <span data-es style="display:none">{subjectEs}</span>
                        </span>
                      </td>
                    );
                  })}
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

    </div>
  </details>

  <!-- ============================================================== -->
  <!-- GROUP 3 — WHAT WE'RE LEARNING (tabbed)                         -->
  <!-- ============================================================== -->
  <details class="tf-group tf-group--learning">
    <summary class="tf-group-head">
      <div class="tf-group-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="#2d8a4e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
      </div>
      <div class="tf-group-meta">
        <h2 class="tf-display">
          <span data-en>What We're Learning</span>
          <span data-es style="display:none">Lo Que Estamos Aprendiendo</span>
        </h2>
        <div class="tf-group-peek">
          <span data-en>
            Welcome · Math · Literacy{hasBooks ? ' · Books' : ''}
          </span>
          <span data-es style="display:none">
            Bienvenida · Mates · Lectura{hasBooks ? ' · Libros' : ''}
          </span>
        </div>
      </div>
      <span class="tf-chev"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></span>
    </summary>
    <div class="tf-group-body">

      <!-- Learning tabs -->
      <div class="tf-learning-tabs" role="tablist">
        <button class="tf-learning-tab tf-learning-tab--active" data-tf-panel="welcome">
          <span class="tf-tab-e">👋</span>
          <span data-en>Welcome</span>
          <span data-es style="display:none">Bienvenida</span>
        </button>
        <button class="tf-learning-tab" data-tf-panel="math">
          <span class="tf-tab-e">🔢</span>
          <span data-en>Math</span>
          <span data-es style="display:none">Matemáticas</span>
        </button>
        <button class="tf-learning-tab" data-tf-panel="literacy">
          <span class="tf-tab-e">📖</span>
          <span data-en>Literacy</span>
          <span data-es style="display:none">Lectura</span>
        </button>
        {hasBooks && (
          <button class="tf-learning-tab" data-tf-panel="books">
            <span class="tf-tab-e">📚</span>
            <span data-en>Books</span>
            <span data-es style="display:none">Libros</span>
          </button>
        )}
      </div>

      <!-- Welcome panel -->
      <div class="tf-learning-panel tf-learning-panel--welcome tf-learning-panel--active">
        <div class="tf-panel-card">
          <h3 class="tf-display tf-welcome-h3">
            <span data-en>From your teacher</span>
            <span data-es style="display:none">De tu maestra</span>
          </h3>
          <div data-lang-en><p set:html={textToHTML(weekData.welcome.en)} /></div>
          <div data-lang-es style="display:none"><p set:html={textToHTML(weekData.welcome.es)} /></div>
        </div>
      </div>

      <!-- Math panel -->
      <div class="tf-learning-panel tf-learning-panel--math">
        <div class="tf-panel-card tf-panel-card--math">
          <h3 class="tf-display tf-math-h3">
            <span data-en>{labelsEn.mathHeading}</span>
            <span data-es style="display:none">{labelsEs.mathHeading}</span>
          </h3>
          <div data-lang-en><p set:html={textToHTML(weekData.math.en)} /></div>
          <div data-lang-es style="display:none"><p set:html={textToHTML(weekData.math.es)} /></div>
          {weekData.mathDetails && (
            <div class="tf-math-details">
              <div class="tf-math-detail-row" data-lang-en>
                <span class="tf-math-detail-label">{labelsEn.mathDetailsModule}</span>
                <span class="tf-math-detail-val">{weekData.mathDetails.module.en}</span>
              </div>
              <div class="tf-math-detail-row" data-lang-en>
                <span class="tf-math-detail-label">{labelsEn.mathDetailsTopic}</span>
                <span class="tf-math-detail-val">{weekData.mathDetails.topic.en}</span>
              </div>
              <div class="tf-math-detail-row" data-lang-en>
                <span class="tf-math-detail-label">{labelsEn.mathDetailsLesson}</span>
                <span class="tf-math-detail-val">{weekData.mathDetails.lesson.en}</span>
              </div>
              <div class="tf-math-detail-row" data-lang-es style="display:none">
                <span class="tf-math-detail-label">{labelsEs.mathDetailsModule}</span>
                <span class="tf-math-detail-val">{weekData.mathDetails.module.es}</span>
              </div>
              <div class="tf-math-detail-row" data-lang-es style="display:none">
                <span class="tf-math-detail-label">{labelsEs.mathDetailsTopic}</span>
                <span class="tf-math-detail-val">{weekData.mathDetails.topic.es}</span>
              </div>
              <div class="tf-math-detail-row" data-lang-es style="display:none">
                <span class="tf-math-detail-label">{labelsEs.mathDetailsLesson}</span>
                <span class="tf-math-detail-val">{weekData.mathDetails.lesson.es}</span>
              </div>
            </div>
          )}
        </div>
      </div>

      <!-- Literacy panel -->
      <div class="tf-learning-panel tf-learning-panel--literacy">
        <div class="tf-panel-card tf-panel-card--literacy">
          <h3 class="tf-display tf-lit-h3">
            <span data-en>{labelsEn.literacyHeading}</span>
            <span data-es style="display:none">{labelsEs.literacyHeading}</span>
          </h3>
          <div data-lang-en><p set:html={textToHTML(weekData.literacy.en)} /></div>
          <div data-lang-es style="display:none"><p set:html={textToHTML(weekData.literacy.es)} /></div>
        </div>
      </div>

      <!-- Books panel (only if books exist) -->
      {hasBooks && (
        <div class="tf-learning-panel tf-learning-panel--books">
          <div class="tf-panel-card tf-panel-card--books">
            <h3 class="tf-display tf-books-h3">
              <span data-en>{labelsEn.booksHeading}</span>
              <span data-es style="display:none">{labelsEs.booksHeading}</span>
            </h3>
            {weekData.books.map((book: any) => (
              <div class="tf-book-item">
                <span class="tf-book-icon">📕</span>
                <div>
                  <div class="tf-book-title">
                    <span data-en={book.title.en} data-es={book.title.es}>{book.title.en}</span>
                  </div>
                  <div class="tf-book-author">
                    <span data-en={`by ${book.author}`} data-es={`por ${book.author}`}>by {book.author}</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

    </div>
  </details>

  <!-- ============================================================== -->
  <!-- GROUP 4 — TALK AT HOME                                          -->
  <!-- ============================================================== -->
  {(hasAsk || hasVocab) && (
    <details class="tf-group tf-group--talk">
      <summary class="tf-group-head">
        <div class="tf-group-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="#047857" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
        </div>
        <div class="tf-group-meta">
          <h2 class="tf-display">
            <span data-en>Talk At Home</span>
            <span data-es style="display:none">Conversar en Casa</span>
          </h2>
          <div class="tf-group-peek">
            <span data-en>
              {askCount > 0 && `${askCount} question${askCount !== 1 ? 's' : ''}`}
              {askCount > 0 && vocabWordCount > 0 && ' · '}
              {vocabWordCount > 0 && `${vocabWordCount} vocabulary word${vocabWordCount !== 1 ? 's' : ''}`}
            </span>
            <span data-es style="display:none">
              {askCount > 0 && `${askCount} pregunta${askCount !== 1 ? 's' : ''}`}
              {askCount > 0 && vocabWordCount > 0 && ' · '}
              {vocabWordCount > 0 && `${vocabWordCount} palabra${vocabWordCount !== 1 ? 's' : ''} de vocabulario`}
            </span>
          </div>
        </div>
        <span class="tf-chev"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></span>
      </summary>
      <div class="tf-group-body">

        {hasAsk && (
          <ul class="tf-ask-list">
            {weekData.askYourChild.map((item: any) => (
              <li>
                <span data-lang-en>{item.en}</span>
                <span data-lang-es style="display:none">{item.es}</span>
              </li>
            ))}
          </ul>
        )}

        {hasVocab && (
          <div class="tf-vocab-section">
            <h4 class="tf-vocab-head">
              📝&nbsp;
              <span data-en>Words of the Week</span>
              <span data-es style="display:none">Palabras de la Semana</span>
              <span class="tf-vocab-flip-hint">
                <span data-en>tap to flip</span>
                <span data-es style="display:none">toca para girar</span>
              </span>
            </h4>

            {vocabIsGrouped ? (
              (weekData.vocabulary.en as {label:string,words:string[],frontLang?:string}[]).map((enGroup, gi) => {
                const esGroup = (weekData.vocabulary.es as {label:string,words:string[],frontLang?:string}[])[gi];
                const frontLang = enGroup.frontLang || esGroup?.frontLang;
                const fGroup = frontLang === 'es' ? esGroup : enGroup;
                const bGroup = frontLang === 'es' ? enGroup : esGroup;
                return (
                  <div class="tf-vocab-group">
                    <div class="tf-vocab-group-lbl">
                      <span data-en={enGroup.label} data-es={esGroup?.label}>{enGroup.label}</span>
                    </div>
                    <div class="tf-vocab-pills">
                      {fGroup.words.map((word: string, wi: number) => (
                        <span class="tf-vocab-pill"
                              data-tf-en-word={fGroup.words[wi]}
                              data-tf-es-word={bGroup?.words[wi] ?? word}
                              data-tf-front-lang={frontLang || ''}>
                          {word}
                        </span>
                      ))}
                    </div>
                  </div>
                );
              })
            ) : (
              <div class="tf-vocab-group">
                <div class="tf-vocab-pills" data-lang-en>
                  {(weekData.vocabulary.en as string[]).map((word: string, i: number) => (
                    <span class="tf-vocab-pill"
                          data-tf-en-word={word}
                          data-tf-es-word={(weekData.vocabulary.es as string[])[i]}>
                      {word}
                    </span>
                  ))}
                </div>
                <div class="tf-vocab-pills" data-lang-es style="display:none">
                  {(weekData.vocabulary.es as string[]).map((word: string, i: number) => (
                    <span class="tf-vocab-pill"
                          data-tf-en-word={(weekData.vocabulary.en as string[])[i]}
                          data-tf-es-word={word}>
                      {word}
                    </span>
                  ))}
                </div>
              </div>
            )}
          </div>
        )}

      </div>
    </details>
  )}

  <!-- ============================================================== -->
  <!-- GROUP 5 — ROARS                                                 -->
  <!-- ============================================================== -->
  <details class="tf-group tf-group--roars" open>
    <summary class="tf-group-head">
      <div class="tf-group-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="#c2410c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
      </div>
      <div class="tf-group-meta">
        <h2 class="tf-display">ROARS</h2>
        <div class="tf-group-peek">
          <span data-en>This week's shout-outs</span>
          <span data-es style="display:none">Reconocimientos de la semana</span>
        </div>
      </div>
      <span class="tf-chev"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></span>
    </summary>
    <div class="tf-group-body">
      <p class="tf-roars-intro">
        <span data-en>Congratulations to this week's ROARS students for showing outstanding character!</span>
        <span data-es style="display:none">¡Felicitaciones a los estudiantes ROARS de esta semana por demostrar carácter sobresaliente!</span>
      </p>
      <div class="tf-roars-grid">
        {config.classrooms.map((classroom) => {
          const student = weekData.roars?.[classroom as keyof typeof weekData.roars];
          if (!student) return null;
          const flagSrc = getFlagSrc(classroom);
          return (
            <div class="tf-roars-card">
              <span class="tf-roars-star">★</span>
              <div class="tf-roars-flag-chip">
                {flagSrc && <img src={flagSrc} alt="" />}
                {classroom}
              </div>
              <div class="tf-roars-name">{student}</div>
            </div>
          );
        })}
      </div>
    </div>
  </details>

  <!-- FOOTER -->
  <footer class="tf-footer">
    <p>
      <span data-en>Bancroft Elementary School · First Grade</span>
      <span data-es style="display:none">Bancroft Elementary School · Primer Grado</span>
    </p>
  </footer>

</div><!-- /tf-wrap -->

