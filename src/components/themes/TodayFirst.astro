<!-- ================================================================
     CLIENT SCRIPT — all selectors use .tf-* so they find nothing
     in Classic or other theme DOMs
     ================================================================ -->
<script define:vars={{ weekDate: date, weekDataJson: JSON.stringify({ reminders: sortedReminders, specials }), configJson: JSON.stringify({ classrooms: config.classrooms, rotations: config.rotations, subjectIcons: config.subjectIcons, subjectTranslations: config.subjectTranslations }), calendarData: calendar }}>

(function TodayFirstInit() {
  // ---------------------------------------------------------------
  // Language button sync (delegates to global setLang if available)
  // ---------------------------------------------------------------
  document.querySelectorAll('.tf-lang-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const lang = btn.dataset.setLang;
      if (typeof window.setLang === 'function') {
        window.setLang(lang);
      } else {
        document.documentElement.dataset.lang = lang;
        localStorage.setItem('nl-lang', lang);
        applyLangManual(lang);
      }
    });
  });

  function applyLangManual(lang) {
    // Minimal fallback if global setLang not yet wired
    document.querySelectorAll('[data-en]').forEach(el => {
      if (el.dataset.en !== undefined) el.textContent = lang === 'en' ? (el.dataset.en || el.textContent) : (el.dataset.es || el.textContent);
    });
    document.querySelectorAll('[data-lang-en]').forEach(el => {
      el.style.display = lang === 'en' ? '' : 'none';
    });
    document.querySelectorAll('[data-lang-es]').forEach(el => {
      el.style.display = lang === 'es' ? '' : 'none';
    });
    document.querySelectorAll('.tf-lang-btn').forEach(b => {
      b.classList.toggle('active', b.dataset.setLang === lang);
    });
  }

  // Sync active state on lang buttons when global lang changes
  const langObserver = new MutationObserver(() => {
    const lang = document.documentElement.getAttribute('data-lang') || 'en';
    document.querySelectorAll('.tf-lang-btn').forEach(b => {
      b.classList.toggle('active', b.dataset.setLang === lang);
    });
  });
  langObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-lang'] });

  // ---------------------------------------------------------------
  // Learning panel tabs
  // ---------------------------------------------------------------
  document.querySelectorAll('.tf-learning-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      const panel = btn.dataset.tfPanel;
      const groupBody = btn.closest('.tf-group-body');
      if (!groupBody) return;
      groupBody.querySelectorAll('.tf-learning-tab').forEach(b =>
        b.classList.toggle('tf-learning-tab--active', b === btn)
      );
      groupBody.querySelectorAll('.tf-learning-panel').forEach(p =>
        p.classList.toggle('tf-learning-panel--active', p.classList.contains('tf-learning-panel--' + panel))
      );
    });
  });

  // ---------------------------------------------------------------
  // Vocabulary flip
  // ---------------------------------------------------------------
  document.querySelectorAll('.tf-vocab-pill').forEach(pill => {
    const en = pill.dataset.tfEnWord || '';
    const es = pill.dataset.tfEsWord || '';
    const frontLang = pill.dataset.tfFrontLang || '';

    function syncFront() {
      const lang = document.documentElement.getAttribute('data-lang') || 'en';
      const isFlipped = pill.classList.contains('tf-vocab-pill--flipped');
      if (frontLang) {
        // Fixed front lang (e.g. SLA always shows Spanish on front)
        pill.textContent = isFlipped ? (frontLang === 'es' ? en : es) : (frontLang === 'es' ? es : en);
      } else {
        pill.textContent = isFlipped ? (lang === 'en' ? es : en) : (lang === 'en' ? en : es);
      }
    }

    pill.addEventListener('click', () => {
      pill.classList.toggle('tf-vocab-pill--flipped');
      syncFront();
    });

    // Re-sync on language change
    const obs = new MutationObserver(syncFront);
    obs.observe(document.documentElement, { attributes: true, attributeFilter: ['data-lang'] });

    // Initial render
    syncFront();
  });

  // ---------------------------------------------------------------
  // Classroom selector
  // ---------------------------------------------------------------
  const cfg = JSON.parse(configJson);
  // Don't auto-pick a default — we don't want to mislead parents into thinking
  // the first classroom's special is "their" child's. They must tap their class.
  const savedClassroom = localStorage.getItem('nl-classroom') || null;

  function selectClassroom(name) {
    // Update pills
    document.querySelectorAll('.tf-room-pill').forEach(pill => {
      pill.classList.toggle('tf-room-pill--active', pill.dataset.tfClassroom === name);
    });
    // Update selected label
    const lbl = document.getElementById('tf-room-selected-name');
    if (lbl) lbl.textContent = name + ' ✓';
    // Show correct specials card
    document.querySelectorAll('[data-tf-specials-classroom]').forEach(card => {
      card.style.display = card.dataset.tfSpecialsClassroom === name ? '' : 'none';
    });
    // Highlight row in full grid
    document.querySelectorAll('[data-tf-grid-classroom]').forEach(row => {
      const cells = row.querySelectorAll('td');
      cells.forEach(td => {
        td.style.background = row.dataset.tfGridClassroom === name ? 'var(--tf-spec-bg)' : '';
      });
    });
    // Update today hero specials
    updateTodaySpecials(name);
    // Flash my-specials card
    const ms = document.getElementById('tf-my-specials');
    if (ms && typeof ms.animate === 'function') {
      ms.animate(
        [
          { boxShadow: '0 0 0 0 rgba(109,40,217,0.0)' },
          { boxShadow: '0 0 0 8px rgba(109,40,217,0.18)' },
          { boxShadow: '0 0 0 0 rgba(109,40,217,0.0)' }
        ],
        { duration: 900, easing: 'cubic-bezier(0.16,1,0.3,1)' }
      );
    }
    localStorage.setItem('nl-classroom', name);
  }

  document.querySelectorAll('.tf-room-pill').forEach(pill => {
    pill.addEventListener('click', () => selectClassroom(pill.dataset.tfClassroom));
  });

  // ---------------------------------------------------------------
  // "Today" hero: recompute for the real calendar day
  // ---------------------------------------------------------------
  const weekDataParsed = JSON.parse(weekDataJson);
  const specials = weekDataParsed.specials;

  const dayKeys = ['monday', 'tuesday', 'wednesday', 'thursday', 'friday'];
  const dayNamesEn = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'];
  const dayNamesEs = ['Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes'];
  const monthNamesEn = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  const monthNamesEs = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];

  function getWeekBounds() {
    const [y, m, d] = weekDate.split('-').map(Number);
    const monday = new Date(y, m - 1, d);
    const friday = new Date(monday);
    friday.setDate(friday.getDate() + 4);
    return { monday, friday };
  }

  function updateTodaySpecials(classroom) {
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    const { monday, friday } = getWeekBounds();

    let dayIndex = 0; // default Monday
    if (today >= monday && today <= friday) {
      dayIndex = today.getDay() - 1; // Mon=1 → 0, Fri=5 → 4
    }
    const dayKey = dayKeys[dayIndex];
    const letter = specials[dayKey] || specials['monday'];

    const enEl = document.getElementById('tf-today-special-en');
    const esEl = document.getElementById('tf-today-special-es');

    // No classroom chosen yet → keep the neutral "Day F · pick your class below" SSR fallback.
    if (!classroom) {
      if (enEl) enEl.innerHTML = `<span class="tf-emoji">📅</span> Day ${letter} <span class="tf-pick-hint" style="opacity:.65">· pick your class below</span>`;
      if (esEl) esEl.innerHTML = `<span class="tf-emoji">📅</span> Día ${letter} <span class="tf-pick-hint" style="opacity:.65">· elige tu salón abajo</span>`;
      return;
    }

    const rotation = cfg.rotations[classroom] || {};
    const subject = rotation[letter] || '';
    const subjectEs = (cfg.subjectTranslations || {})[subject] || subject;
    const icon = (cfg.subjectIcons || {})[subject] || '';

    if (enEl) enEl.innerHTML = (icon ? `<span class="tf-emoji">${icon}</span>` : '') + `${subject} <span style="opacity:.65">(Day ${letter})</span>`;
    if (esEl) esEl.innerHTML = (icon ? `<span class="tf-emoji">${icon}</span>` : '') + `${subjectEs} <span style="opacity:.65">(Día ${letter})</span>`;

    // Also mark today's day in the ms-grid
    const classroom_specials = document.querySelector(`[data-tf-specials-classroom="${classroom}"]`);
    if (classroom_specials) {
      classroom_specials.querySelectorAll('.tf-ms-day').forEach((dayEl, i) => {
        dayEl.classList.toggle('tf-ms-day--today', i === dayIndex);
      });
    }
  }

  function updateTodayHero() {
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    const { monday, friday } = getWeekBounds();

    // Only update day name if today is within the week
    if (today >= monday && today <= friday) {
      const dayIndex = today.getDay() - 1;
      const nameEn = dayNamesEn[dayIndex];
      const nameEs = dayNamesEs[dayIndex];
      const monthEn = monthNamesEn[today.getMonth()];
      const monthEs = monthNamesEs[today.getMonth()];
      const dayNum = today.getDate();

      const dayNameEl = document.getElementById('tf-today-day-name');
      if (dayNameEl) {
        const enSpan = dayNameEl.querySelector('[data-en]');
        const esSpan = dayNameEl.querySelector('[data-es]');
        if (enSpan) enSpan.innerHTML = `${nameEn} <em>${monthEn} ${dayNum}</em>`;
        if (esSpan) esSpan.innerHTML = `${nameEs} <em>${dayNum} ${monthEs}</em>`;
      }
    }

    // Update Next Up: earliest reminder after today
    const reminders = weekDataParsed.reminders || [];
    const todayISO = today.toISOString().split('T')[0];
    const future = reminders.filter(r => r.date >= todayISO);
    const nextReminder = future[0] || reminders[0];
    if (nextReminder) {
      const enEl = document.getElementById('tf-next-up-en');
      const esEl = document.getElementById('tf-next-up-es');
      const strippedEn = nextReminder.en.replace(/<[^>]+>/g, '').slice(0, 55);
      const strippedEs = nextReminder.es.replace(/<[^>]+>/g, '').slice(0, 55);
      if (enEl) enEl.textContent = strippedEn;
      if (esEl) esEl.textContent = strippedEs;
    }
  }

  updateTodayHero();

  // Init classroom: only apply a saved selection. Don't auto-pick a default
  // — Cartagena's special is not necessarily this family's child's special.
  if (savedClassroom) {
    selectClassroom(savedClassroom);
  } else {
    // No saved choice → leave pills inactive, hide per-classroom specials card,
    // and render neutral "Day F" in the hero.
    document.querySelectorAll('[data-tf-specials-classroom]').forEach(card => {
      card.style.display = 'none';
    });
    const lbl = document.getElementById('tf-room-selected-name');
    if (lbl) lbl.textContent = '';
    updateTodaySpecials(null);
  }

  // ---------------------------------------------------------------
  // Milestone trail: live recomputation using calendar data
  // ---------------------------------------------------------------
  (function updateTrail() {
    try {
      const parseDate = s => { const [y, m, d] = s.split('-').map(Number); return new Date(y, m - 1, d); };
      const fmtISO = d => `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;

      const firstDay = parseDate(calendarData.firstDay);
      const lastDay = parseDate(calendarData.lastDay);
      const noSchool = new Set();
      (calendarData.dates || []).forEach(d => noSchool.add(d.date));
      (calendarData.breaks || []).forEach(br => {
        const d = parseDate(br.start), end = parseDate(br.end);
        while (d <= end) { noSchool.add(fmtISO(d)); d.setDate(d.getDate()+1); }
      });

      const countWeekdays = (start, end) => {
        let count = 0, d = new Date(start);
        while (d <= end) { const dow = d.getDay(); if (dow >= 1 && dow <= 5 && !noSchool.has(fmtISO(d))) count++; d.setDate(d.getDate()+1); }
        return count;
      };

      const today = new Date(); today.setHours(0,0,0,0);
      const effective = today > lastDay ? lastDay : today < firstDay ? firstDay : today;
      const total = countWeekdays(firstDay, lastDay);
      const elapsed = countWeekdays(firstDay, effective);
      const remaining = Math.max(0, total - elapsed);
      const pct = Math.min(100, Math.round((elapsed / total) * 100));

      const elapsedEl = document.getElementById('tf-trail-elapsed');
      if (elapsedEl) elapsedEl.textContent = String(elapsed);
      const remainEl = document.getElementById('tf-trail-remaining');
      if (remainEl) remainEl.textContent = String(remaining);
      const fillEl = document.getElementById('tf-trail-fill');
      if (fillEl) fillEl.style.width = pct + '%';
      const nowEl = document.getElementById('tf-trail-now');
      if (nowEl) nowEl.style.left = pct + '%';
    } catch (e) { /* non-critical */ }
  })();

  // ---------------------------------------------------------------
  // Weather — Open-Meteo
  // ---------------------------------------------------------------
  (async function loadWeather() {
    const weekStart = new Date(weekDate + 'T00:00:00');
    const now = new Date();
    const diffDays = Math.abs((now.getTime() - weekStart.getTime()) / (1000 * 60 * 60 * 24));
    if (diffDays > 10) return;

    const weekEnd = new Date(weekStart);
    weekEnd.setDate(weekEnd.getDate() + 4);
    const endStr = weekEnd.toISOString().split('T')[0];

    const weatherCodes = {
      0:'☀️',1:'🌤️',2:'⛅',3:'☁️',
      45:'🌫️',48:'🌫️',
      51:'🌦️',53:'🌧️',55:'🌧️',
      61:'🌧️',63:'🌧️',65:'🌧️',
      71:'🌨️',73:'🌨️',75:'🌨️',
      80:'🌦️',81:'🌧️',82:'🌧️',
      95:'⛈️',96:'⛈️',99:'⛈️',
    };

    try {
      const url = `https://api.open-meteo.com/v1/forecast?latitude=38.9283&longitude=-77.0365&daily=temperature_2m_max,temperature_2m_min,precipitation_probability_max,weathercode&temperature_unit=fahrenheit&timezone=America/New_York&start_date=${weekDate}&end_date=${endStr}`;
      const resp = await fetch(url);
      if (!resp.ok) return;
      const data = await resp.json();
      const daily = data.daily;
      if (!daily || !daily.time) return;

      // "Today" card weather
      const today = new Date(); today.setHours(0,0,0,0);
      const weekStartD = new Date(weekDate + 'T00:00:00');
      let todayIdx = 0;
      if (today >= weekStartD && today <= weekEnd) {
        todayIdx = today.getDay() - 1;
      }
      if (todayIdx >= 0 && todayIdx < daily.time.length) {
        const high = Math.round(daily.temperature_2m_max[todayIdx]);
        const low  = Math.round(daily.temperature_2m_min[todayIdx]);
        const code = daily.weathercode[todayIdx];
        const icon = weatherCodes[code] || '🌡️';
        const weatherText = document.getElementById('tf-weather-text');
        if (weatherText) weatherText.textContent = `${icon} ${high}°/${low}°F`;
      }

      // Per-day weather slots in specials grid
      for (let i = 0; i < daily.time.length && i < 5; i++) {
        const high = Math.round(daily.temperature_2m_max[i]);
        const low  = Math.round(daily.temperature_2m_min[i]);
        const precip = daily.precipitation_probability_max[i];
        const code = daily.weathercode[i];
        const icon = weatherCodes[code] || '🌡️';
        const html = `<span>${icon} ${high}°/${low}°${precip > 20 ? ` 💧${precip}%` : ''}</span>`;
        document.querySelectorAll(`[data-weather-day="${i}"] .tf-weather-slot`).forEach(slot => {
          slot.innerHTML = html;
        });
      }
    } catch (e) { /* weather non-critical */ }
  })();

  // Re-trigger today logic when user switches back to this theme
  window.addEventListener('nl-theme-change', (e) => {
    if (e && e.detail && e.detail.theme === 'A') {
      const classroom = localStorage.getItem('nl-classroom') || cfg.classrooms[0];
      selectClassroom(classroom);
      updateTodayHero();
    }
  });

})();
</script>
