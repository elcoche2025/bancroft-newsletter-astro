<script define:vars={{
  weekDate: date,
  calendarData: calendar,
  configData: config,
  specialsData: specials,
  dayShortEnData: dayShortEn,
  dayShortEsData: dayShortEs,
  dayAbbrevEnData: dayAbbrevEn,
  dayAbbrevEsData: dayAbbrevEs,
  subjectShortEnData: subjectShortEn,
  subjectShortEsData: subjectShortEs,
  remindersData: sortedReminders,
}}>
(function pkInit() {
  // ── Helpers ──────────────────────────────────────────────────────────────
  const parseDate = (s) => { const [y, m, d] = s.split('-').map(Number); return new Date(y, m - 1, d); };
  const fmtISO = (d) => `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;

  // ── Live progress bar ──────────────────────────────────────────────────
  (function updateProgress() {
    try {
      const noSchool = new Set();
      (calendarData.dates || []).forEach(d => noSchool.add(d.date));
      (calendarData.breaks || []).forEach(br => {
        const d = parseDate(br.start), end = parseDate(br.end);
        while (d <= end) { noSchool.add(fmtISO(d)); d.setDate(d.getDate()+1); }
      });
      const countWD = (start, end) => {
        let n = 0, d = new Date(start);
        while (d <= end) { const dow = d.getDay(); if (dow>=1&&dow<=5&&!noSchool.has(fmtISO(d))) n++; d.setDate(d.getDate()+1); }
        return n;
      };
      const first = parseDate(calendarData.firstDay);
      const last  = parseDate(calendarData.lastDay);
      const today = new Date(); today.setHours(0,0,0,0);
      const eff   = today > last ? last : today < first ? first : today;
      const total   = countWD(first, last);
      const elapsed = countWD(first, eff);
      const remaining = Math.max(0, total - elapsed);
      const pct = Math.min(100, Math.round(elapsed / total * 100));
      const elEl = document.getElementById('pk-days-elapsed');
      const remEl = document.getElementById('pk-days-remaining');
      const fillEl = document.getElementById('pk-prog-fill');
      if (elEl)  elEl.textContent = String(elapsed);
      if (remEl) remEl.textContent = String(remaining);
      if (fillEl) fillEl.style.width = pct + '%';
    } catch(e) {}
  })();

  // ── ATH dismiss ──────────────────────────────────────────────────────
  (function initATH() {
    const ath = document.getElementById('pk-ath');
    if (!ath) return;
    try {
      if (localStorage.getItem('nl-ath-dismissed') === '1') { ath.classList.add('pk-hidden'); return; }
    } catch(e) {}
    const btn = document.getElementById('pk-ath-dismiss');
    if (btn) btn.addEventListener('click', () => {
      ath.classList.add('pk-hidden');
      try { localStorage.setItem('nl-ath-dismissed', '1'); } catch(e) {}
    });
  })();

  // ── Lang pill active state (mirrors setLang from layout) ────────────
  function updateLangPill() {
    const lang = document.documentElement.getAttribute('data-lang') || 'en';
    document.querySelectorAll('.pk-lang-pill .lang-btn').forEach(btn => {
      btn.classList.toggle('pk-active', btn.dataset.setLang === lang);
    });
  }
  new MutationObserver(updateLangPill).observe(document.documentElement, { attributes: true, attributeFilter: ['data-lang'] });
  updateLangPill();

  // ── Hero Today (live date) ──────────────────────────────────────────
  (function initHero() {
    try {
      const weekStart = parseDate(weekDate); // Monday
      const weekEnd   = new Date(weekStart); weekEnd.setDate(weekEnd.getDate()+4); // Friday
      const today     = new Date(); today.setHours(0,0,0,0);
      if (today < weekStart || today > weekEnd) return; // not this week — keep server SSR

      const dayNames = {
        en: ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'],
        es: ['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'],
      };
      const dow = today.getDay();
      const monthEn = today.toLocaleDateString('en-US', { month: 'short' });
      const monthEs = today.toLocaleDateString('es-US', { month: 'short' });
      const dayNum   = today.getDate();

      // Kicker
      const kickerEl = document.getElementById('pk-hero-kicker-text');
      if (kickerEl) {
        kickerEl.setAttribute('data-en', `Today · ${dayNames.en[dow]}`);
        kickerEl.setAttribute('data-es', `Hoy · ${dayNames.es[dow]}`);
        kickerEl.textContent = `Today · ${dayNames.en[dow]}`;
      }

      // Month/Day
      const monthEl = document.getElementById('pk-hero-month');
      const dayEl   = document.getElementById('pk-hero-day');
      if (monthEl) { monthEl.textContent = monthEn; monthEl.dataset.en = monthEn; monthEl.dataset.es = monthEs; }
      if (dayEl)   { dayEl.textContent = String(dayNum); }

      // Today's special — only show the subject if the family has explicitly
      // picked their classroom. Otherwise leave the neutral "Day F" SSR fallback
      // so we don't suggest some other classroom's special is theirs.
      const dayKeys = ['monday','tuesday','wednesday','thursday','friday'];
      const dayIdx  = dow >= 1 && dow <= 5 ? dow - 1 : 0;
      const todayDayKey = dayKeys[dayIdx];
      const todayLetter = specialsData[todayDayKey] || specialsData['monday'];

      let classroom = null;
      try { classroom = localStorage.getItem('nl-classroom'); } catch(e) {}

      const specialEl = document.getElementById('pk-today-special');
      if (specialEl) {
        if (classroom && configData.rotations[classroom]) {
          const subject = configData.rotations[classroom][todayLetter] || '';
          const icon    = (configData.subjectIcons || {})[subject] || '📅';
          const subEn   = subject;
          const subEs   = (configData.subjectTranslations || {})[subject] || subject;
          specialEl.innerHTML = `<span class="pk-chip-e">${icon}</span><span data-en="${subEn} · ${todayLetter}" data-es="${subEs} · ${todayLetter}">${subEn} · ${todayLetter}</span>`;
        } else {
          // Refresh the neutral fallback in case the day-letter changed (e.g., week boundary)
          specialEl.innerHTML = `<span class="pk-chip-e">📅</span><span data-en="Day ${todayLetter}" data-es="Día ${todayLetter}">Day ${todayLetter}</span>`;
        }
      }

      // Up Next — recompute live: earliest reminder dated strictly after today.
      try {
        const todayISO = today.toISOString().slice(0, 10);
        const future = (remindersData || []).filter(r => r.date > todayISO);
        const next = future[0];
        if (next) {
          const upNextEl = document.getElementById('pk-up-next');
          if (upNextEl) {
            const d = parseDate(next.date);
            const monNext = d.toLocaleDateString('en-US', { month: 'short' });
            const monNextEs = d.toLocaleDateString('es-US', { month: 'short' });
            const dNum = d.getDate();
            // Extract a short label from <b>...</b> in the reminder body
            const extractLabel = (html, fallback) => {
              if (!html) return fallback;
              const re = new RegExp('<' + 'b>' + '([^<]{1,120})' + '<\\/b>');
              const m = html.match(re);
              const raw = m ? m[1] : html.replace(/<[^>]+>/g, '');
              return raw.split('—')[0].split('·')[0].trim().slice(0, 30);
            };
            const labelEn = extractLabel(next.en, next.date);
            const labelEs = extractLabel(next.es || next.en, labelEn);
            const valEn = `${labelEn} · ${monNext} ${dNum}`;
            const valEs = `${labelEs} · ${monNextEs} ${dNum}`;
            upNextEl.innerHTML = `<span class="pk-chip-e">📌</span><span data-en="${valEn.replace(/"/g, '&quot;')}" data-es="${valEs.replace(/"/g, '&quot;')}">${valEn}</span>`;
          }
        }
      } catch(e) {}
    } catch(e) {}
  })();

  // ── Weather ──────────────────────────────────────────────────────────
  (async function loadWeather() {
    const weatherEl = document.getElementById('pk-hero-weather');
    if (!weatherEl) return;

    const weekStart = parseDate(weekDate);
    const weekEnd   = new Date(weekStart); weekEnd.setDate(weekEnd.getDate()+4);
    const today     = new Date(); today.setHours(0,0,0,0);
    if (today < weekStart || today > weekEnd) return;

    const diffDays = Math.abs((today.getTime() - weekStart.getTime()) / 86400000);
    if (diffDays > 10) return;

    const weatherCodes = {
      0:'☀️',1:'🌤️',2:'⛅',3:'☁️',
      45:'🌫️',48:'🌫️',
      51:'🌦️',53:'🌧️',55:'🌧️',
      61:'🌧️',63:'🌧️',65:'🌧️',
      71:'🌨️',73:'🌨️',75:'🌨️',
      80:'🌦️',81:'🌧️',82:'🌧️',
      95:'⛈️',96:'⛈️',99:'⛈️',
    };

    const lat = 38.9283, lon = -77.0365;
    const todayISO = fmtISO(today);
    try {
      const url = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&daily=temperature_2m_max,weathercode&temperature_unit=fahrenheit&timezone=America/New_York&start_date=${todayISO}&end_date=${todayISO}`;
      const resp = await fetch(url);
      if (!resp.ok) return;
      const data = await resp.json();
      const daily = data.daily;
      if (!daily?.time?.length) return;

      const high = Math.round(daily.temperature_2m_max[0]);
      const code = daily.weathercode[0];
      const wIcon = weatherCodes[code] || '🌡️';

      const lang = document.documentElement.getAttribute('data-lang') || 'en';
      const dismissalEn = `${wIcon} ${high}°F · Dismissal 3:15 pm`;
      const dismissalEs = `${wIcon} ${high}°F · Salida 3:15 pm`;
      weatherEl.setAttribute('data-en', dismissalEn);
      weatherEl.setAttribute('data-es', dismissalEs);
      weatherEl.textContent = lang === 'es' ? dismissalEs : dismissalEn;
    } catch(e) {
      // fail silently — already shows "Dismissal 3:15 pm" from SSR
    }
  })();

  // ── Status bar → scroll to reminders ────────────────────────────────
  (function initStatusBar() {
    const bar  = document.getElementById('pk-status-bar');
    const card = document.getElementById('pk-card-reminders');
    if (!bar || !card) return;
    bar.addEventListener('click', () => {
      card.open = true;
      card.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  })();

  // ── Specials: room tabs + grid update ───────────────────────────────
  (function initSpecials() {
    const tabs   = document.querySelectorAll('.pk-room-tab');
    const grid   = document.getElementById('pk-spec-grid');
    const badge  = document.getElementById('pk-specials-badge');
    const peekEl = document.getElementById('pk-specials-peek');

    if (!grid) return;

    const rotations   = configData.rotations;
    const icons       = configData.subjectIcons;
    const trans       = configData.subjectTranslations;
    const lang = () => document.documentElement.getAttribute('data-lang') || 'en';

    function setActiveTab(classroom) {
      tabs.forEach(t => t.classList.toggle('pk-active', t.dataset.classroom === classroom));
      if (badge) { badge.textContent = classroom; badge.hidden = false; }

      // Update grid cells
      const cells = grid.querySelectorAll('.pk-spec-cell');
      const dayKeys = ['monday','tuesday','wednesday','thursday','friday'];
      cells.forEach((cell, i) => {
        const letter  = specialsData[dayKeys[i]];
        const subject = rotations[classroom]?.[letter] || '';
        const icon    = icons[subject] || '';
        const subEn   = subjectShortEnData[subject] || subject;
        const subEs   = subjectShortEsData[subject] || subject;

        const iconEl  = cell.querySelector('[data-subject-icon]');
        const lblEl   = cell.querySelector('[data-subject-label]');
        const letEl   = cell.querySelector('[data-letter-label]');
        if (iconEl)  iconEl.textContent = icon;
        if (lblEl)   { lblEl.setAttribute('data-en', subEn); lblEl.setAttribute('data-es', subEs); lblEl.textContent = lang() === 'es' ? subEs : subEn; }
        if (letEl)   letEl.textContent = letter;
      });

      // Rebuild peek
      const peekEn = dayKeys.map((day, i) => {
        const letter  = specialsData[day];
        const subject = rotations[classroom]?.[letter] || '';
        return `${dayAbbrevEnData[i]} ${subjectShortEnData[subject] || subject}`;
      }).join(' · ');
      const peekEs = dayKeys.map((day, i) => {
        const letter  = specialsData[day];
        const subject = rotations[classroom]?.[letter] || '';
        return `${dayAbbrevEsData[i]} ${subjectShortEsData[subject] || subject}`;
      }).join(' · ');

      if (peekEl) {
        const inner = peekEl.querySelector('[data-en]');
        if (inner) { inner.setAttribute('data-en', peekEn); inner.setAttribute('data-es', peekEs); inner.textContent = lang() === 'es' ? peekEs : peekEn; }
      }

      // Highlight today's column
      const today = new Date();
      const weekStart = parseDate(weekDate);
      const weekEnd   = new Date(weekStart); weekEnd.setDate(weekEnd.getDate()+4);
      today.setHours(0,0,0,0);
      cells.forEach((cell, i) => {
        const cellDate = new Date(weekStart); cellDate.setDate(cellDate.getDate()+i);
        cell.classList.toggle('pk-today', today >= weekStart && today <= weekEnd && cellDate.getTime() === today.getTime());
      });

      // Pulse grid
      grid.animate(
        [{ boxShadow:'0 0 0 0 rgba(109,40,217,0)' },
         { boxShadow:'0 0 0 6px rgba(109,40,217,0.18)' },
         { boxShadow:'0 0 0 0 rgba(109,40,217,0)' }],
        { duration:700, easing:'cubic-bezier(0.16,1,0.3,1)' }
      );

      try { localStorage.setItem('nl-classroom', classroom); } catch(e) {}

      // Sync hero chip so picking a class anywhere updates the top of the page too.
      const heroEl = document.getElementById('pk-today-special');
      if (heroEl) {
        const today = new Date(); today.setHours(0,0,0,0);
        const weekStart = parseDate(weekDate);
        const weekEnd = new Date(weekStart); weekEnd.setDate(weekEnd.getDate()+4);
        const dow = today >= weekStart && today <= weekEnd ? today.getDay() : 1; // Mon fallback
        const dayIdx = dow >= 1 && dow <= 5 ? dow - 1 : 0;
        const todayLetter = specialsData[dayKeys[dayIdx]] || specialsData['monday'];
        const subject = (configData.rotations[classroom] || {})[todayLetter] || '';
        const heroIcon = (configData.subjectIcons || {})[subject] || '📅';
        const subEn = subject;
        const subEs = (configData.subjectTranslations || {})[subject] || subject;
        heroEl.innerHTML = `<span class="pk-chip-e">${heroIcon}</span><span data-en="${subEn} · ${todayLetter}" data-es="${subEs} · ${todayLetter}">${subEn} · ${todayLetter}</span>`;
      }
    }

    tabs.forEach(t => {
      t.addEventListener('click', () => setActiveTab(t.dataset.classroom));
    });

    // Restore saved classroom — but ONLY if the family has actively picked one
    // before. Don't pre-select a default (Cartagena isn't necessarily their child's).
    let saved;
    try { saved = localStorage.getItem('nl-classroom'); } catch(e) {}
    if (saved && configData.classrooms.includes(saved)) {
      setActiveTab(saved);
    }

    // Full grid toggle
    const toggleLink = document.getElementById('pk-full-grid-toggle');
    const fullSection = document.getElementById('pk-full-table-section');
    if (toggleLink && fullSection) {
      toggleLink.addEventListener('click', (e) => {
        e.preventDefault();
        const isHidden = fullSection.hasAttribute('hidden');
        if (isHidden) {
          fullSection.removeAttribute('hidden');
          fullSection.removeAttribute('aria-hidden');
          toggleLink.setAttribute('aria-expanded', 'true');
          const lEn = document.documentElement.getAttribute('data-lang') === 'es' ? 'Cerrar cuadrícula' : 'Close full grid';
          toggleLink.querySelector('[data-en]')?.setAttribute('data-en', 'Close full grid');
          toggleLink.querySelector('[data-en]')?.setAttribute('data-es', 'Cerrar cuadrícula');
          if (toggleLink.querySelector('[data-en]')) toggleLink.querySelector('[data-en]').textContent = lEn;
          fullSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        } else {
          fullSection.setAttribute('hidden', '');
          fullSection.setAttribute('aria-hidden', 'true');
          toggleLink.setAttribute('aria-expanded', 'false');
          const lEn = document.documentElement.getAttribute('data-lang') === 'es' ? 'Abrir cuadrícula' : 'Open full grid';
          toggleLink.querySelector('[data-en]')?.setAttribute('data-en', 'Open full grid');
          toggleLink.querySelector('[data-en]')?.setAttribute('data-es', 'Abrir cuadrícula');
          if (toggleLink.querySelector('[data-en]')) toggleLink.querySelector('[data-en]').textContent = lEn;
        }
      });
    }
  })();

  // ── Vocabulary flip ──────────────────────────────────────────────────
  (function initVocab() {
    const lang = () => document.documentElement.getAttribute('data-lang') || 'en';

    function refreshVocab() {
      const currentLang = lang();
      document.querySelectorAll('.pk-vp').forEach(pill => {
        const frontLang = pill.dataset.frontLang;
        const enWord    = pill.dataset.enWord;
        const esWord    = pill.dataset.esWord;
        if (!pill.classList.contains('pk-flipped')) {
          // show front: if frontLang = 'es' always show es; otherwise show current lang
          if (frontLang === 'es') {
            pill.textContent = esWord;
          } else {
            pill.textContent = currentLang === 'es' ? esWord : enWord;
          }
        } else {
          // show back: opposite of front
          if (frontLang === 'es') {
            pill.textContent = enWord;
          } else {
            pill.textContent = currentLang === 'es' ? enWord : esWord;
          }
        }
        pill.dataset.originalText = pill.textContent;
      });
    }

    document.querySelectorAll('.pk-vp').forEach(pill => {
      // Store originals
      pill.dataset.originalText = pill.textContent.trim();
      pill.addEventListener('click', () => {
        const flipped    = pill.classList.toggle('pk-flipped');
        const frontLang  = pill.dataset.frontLang;
        const enWord     = pill.dataset.enWord;
        const esWord     = pill.dataset.esWord;
        const currentLang = lang();
        if (flipped) {
          // show back
          if (frontLang === 'es') { pill.textContent = enWord; }
          else { pill.textContent = currentLang === 'es' ? enWord : esWord; }
        } else {
          // show front
          if (frontLang === 'es') { pill.textContent = esWord; }
          else { pill.textContent = currentLang === 'es' ? esWord : enWord; }
        }
      });
    });

    // Re-orient when language changes
    new MutationObserver(() => {
      document.querySelectorAll('.pk-vp:not(.pk-flipped)').forEach(pill => {
        const frontLang = pill.dataset.frontLang;
        const enWord    = pill.dataset.enWord;
        const esWord    = pill.dataset.esWord;
        const currentLang = lang();
        if (frontLang !== 'es') {
          pill.textContent = currentLang === 'es' ? esWord : enWord;
        }
      });
    }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-lang'] });

    refreshVocab();
  })();

  // ── Ask bubbles: respond to setLang ─────────────────────────────────
  // The layout-level setLang uses innerHTML = getAttribute('data-en|es')
  // which is already handled by the global setLang. No extra work needed.

})();
</script>
