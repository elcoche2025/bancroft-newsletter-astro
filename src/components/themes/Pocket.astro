---
import config from '../../data/config.json';
import calendar from '../../data/calendar.json';
import {
  textToHTML, formatDate, formatDateShort,
  getSubjectIcon, getSpecialForDay, getSubjectTranslation,
  getSchoolYearProgress,
} from '../../lib/utils';

interface Props {
  weekData: any;
  currentDate: string;
  allWeeks: string[];
  issueNumber: number;
}

const { weekData, currentDate, allWeeks, issueNumber } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const date = weekData.date;
const season = weekData.season || 'spring';
const logo = config.seasonLogos[season as keyof typeof config.seasonLogos] || config.seasonLogos.default;

// School year progress (server-side; client script refreshes with today's real date)
const progress = getSchoolYearProgress(date);

// Specials day keys
const dayKeys = ['monday', 'tuesday', 'wednesday', 'thursday', 'friday'] as const;
const specials = weekData.specials as Record<string, string>;

// Day short names for the specials grid
const dayShortEn = ['M', 'T', 'W', 'Th', 'F'];
const dayShortEs = ['L', 'M', 'Mi', 'J', 'V'];

// Full day names for subject translations (bilingual abbreviations for peek)
const dayAbbrevEn = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri'];
const dayAbbrevEs = ['Lun', 'Mar', 'Mié', 'Jue', 'Vie'];

// Subject short labels for the specials peek line
const subjectShortEn: Record<string, string> = { Music: 'Mus', Science: 'Sci', PE: 'PE', Library: 'Lib', Art: 'Art' };
const subjectShortEs: Record<string, string> = { Music: 'Mús', Science: 'Cie', PE: 'EF', Library: 'Bib', Art: 'Arte' };

// Helper: parse a reminder date
function parseReminderDate(dateStr: string) {
  const d = new Date(dateStr + 'T12:00:00');
  return {
    month: d.toLocaleDateString('en-US', { month: 'short' }).toUpperCase(),
    monthEs: d.toLocaleDateString('es-US', { month: 'short' }).toUpperCase(),
    day: d.getDate(),
  };
}

// Sort reminders by date
const sortedReminders = weekData.reminders
  ? [...weekData.reminders].sort((a: any, b: any) => a.date.localeCompare(b.date))
  : [];

// Reminder count badge
const reminderCount = sortedReminders.length;

// Build reminder peek text (up to 3 summaries: "MMM D · …" shape)
function buildReminderPeekEn(reminders: any[]): string {
  if (!reminders.length) return '';
  const parts = reminders.slice(0, 3).map((r: any) => {
    const d = new Date(r.date + 'T12:00:00');
    const mon = d.toLocaleDateString('en-US', { month: 'short' });
    const day = d.getDate();
    // Extract bold text or first 40 chars as summary
    const raw: string = r.en || '';
    const boldMatch = raw.match(/<b>([^<]{1,60})<\/b>/);
    const summary = boldMatch ? boldMatch[1].replace(/\s*—.*/, '').replace(/\s*·.*/, '').trim() : raw.replace(/<[^>]+>/g, '').slice(0, 40).trim();
    return `${mon} ${day} · ${summary.slice(0, 28)}`;
  });
  return parts.join(' · ');
}

function buildReminderPeekEs(reminders: any[]): string {
  if (!reminders.length) return '';
  const parts = reminders.slice(0, 3).map((r: any) => {
    const d = new Date(r.date + 'T12:00:00');
    const mon = d.toLocaleDateString('es-US', { month: 'short' });
    const day = d.getDate();
    const raw: string = r.es || r.en || '';
    const boldMatch = raw.match(/<b>([^<]{1,60})<\/b>/);
    const summary = boldMatch ? boldMatch[1].replace(/\s*—.*/, '').replace(/\s*·.*/, '').trim() : raw.replace(/<[^>]+>/g, '').slice(0, 40).trim();
    return `${mon} ${day} · ${summary.slice(0, 28)}`;
  });
  return parts.join(' · ');
}

const reminderPeekEn = reminderCount
  ? buildReminderPeekEn(sortedReminders)
  : '';
const reminderPeekEs = reminderCount
  ? buildReminderPeekEs(sortedReminders)
  : '';

// Status bar text from first reminder (truncated to ~120 chars)
const firstReminder = sortedReminders[0];
function truncateHTML(html: string, maxLen: number): string {
  const stripped = html.replace(/<[^>]+>/g, '');
  return stripped.length > maxLen ? stripped.slice(0, maxLen).trim() + '…' : stripped;
}
const statusTextEn = firstReminder
  ? truncateHTML(firstReminder.en, 120)
  : '';
const statusTextEs = firstReminder
  ? truncateHTML(firstReminder.es || firstReminder.en, 120)
  : '';

// "Up Next" should be the earliest reminder whose date is >= the newsletter week start.
// At build time we don't know view-time "today"; the client script will recompute live.
// Server-side pick: first reminder on/after weekData.date; fall back to firstReminder.
const weekStartISO = weekData.date;
const upNextReminder =
  sortedReminders.find((r: any) => r.date >= weekStartISO) || firstReminder;

// Up Next short label from the chosen reminder (avoids regex-with-tags in template JSX expressions,
// which confuse the Astro parser into thinking <b> is a tag).
function extractUpNextLabel(html: string, fallback: string): string {
  if (!html) return fallback;
  // Allow up to 120 chars between <b>...</b> so longer bold spans still match.
  const tagPattern = '<' + 'b>' + '([^<]{1,120})' + '<\\/b>';
  const boldMatch = html.match(new RegExp(tagPattern));
  const raw = boldMatch ? boldMatch[1] : html.replace(/<[^>]+>/g, '');
  return raw.split('—')[0].split('·')[0].trim().slice(0, 30);
}
const upNextLabelEn = upNextReminder
  ? extractUpNextLabel(upNextReminder.en, upNextReminder.date)
  : '';
const upNextLabelEs = upNextReminder
  ? extractUpNextLabel(upNextReminder.es || upNextReminder.en, upNextLabelEn)
  : '';
const upNextRD = upNextReminder ? parseReminderDate(upNextReminder.date) : null;

// ROARS count
const roarsCount = weekData.roars
  ? Object.values(weekData.roars).filter(Boolean).length
  : 0;

// Vocab count
let vocabCount = 0;
if (weekData.vocabulary && weekData.vocabulary.en) {
  const enVocab = weekData.vocabulary.en;
  if (Array.isArray(enVocab)) {
    if (typeof enVocab[0] === 'string') {
      vocabCount = enVocab.length;
    } else {
      vocabCount = (enVocab as any[]).reduce((sum: number, g: any) => sum + (g.words?.length || 0), 0);
    }
  }
}

// Vocab grouped detection
const isVocabGrouped = weekData.vocabulary?.en && Array.isArray(weekData.vocabulary.en) &&
  typeof weekData.vocabulary.en[0] === 'object' && weekData.vocabulary.en[0].words;

// Build vocab flip lookup for flat arrays (injected into client script)
type VocabPair = { en: string; es: string };
const vocabPairs: VocabPair[] = [];
if (weekData.vocabulary?.en) {
  const enArr = weekData.vocabulary.en;
  const esArr = weekData.vocabulary.es;
  if (!isVocabGrouped) {
    (enArr as string[]).forEach((w: string, i: number) => {
      vocabPairs.push({ en: w, es: (esArr as string[])[i] || w });
    });
  } else {
    (enArr as any[]).forEach((grp: any, gi: number) => {
      const esGrp = (esArr as any[])[gi];
      const frontLang = grp.frontLang || esGrp?.frontLang;
      grp.words.forEach((word: string, wi: number) => {
        const esWord = esGrp?.words?.[wi] || word;
        if (frontLang === 'es') {
          // front is ES
          vocabPairs.push({ en: esGrp.words[wi] || word, es: word });
        } else {
          vocabPairs.push({ en: word, es: esWord });
        }
      });
    });
  }
}

// Default classroom for specials (server-side = first; client updates from localStorage)
const defaultClassroom = config.classrooms[0];

// Build server-side specials peek for default classroom
function buildSpecialsPeekEn(classroom: string): string {
  return dayKeys.map((day, i) => {
    const letter = specials[day];
    const subject = getSpecialForDay(classroom, letter);
    const short = subjectShortEn[subject] || subject;
    return `${dayAbbrevEn[i]} ${short}`;
  }).join(' · ');
}
function buildSpecialsPeekEs(classroom: string): string {
  return dayKeys.map((day, i) => {
    const letter = specials[day];
    const subject = getSpecialForDay(classroom, letter);
    const short = subjectShortEs[subject] || subject;
    return `${dayAbbrevEs[i]} ${short}`;
  }).join(' · ');
}

const defaultSpecialsPeekEn = buildSpecialsPeekEn(defaultClassroom);
const defaultSpecialsPeekEs = buildSpecialsPeekEs(defaultClassroom);

// Formatted dates
const formattedDateEn = formatDate(date, 'en');
const formattedDateEs = formatDate(date, 'es');

// For hero: the week's Monday is always the date
// We'll use the date itself for display (it's Monday of the week)
const weekDateObj = new Date(date + 'T12:00:00');
const heroMonthEn = weekDateObj.toLocaleDateString('en-US', { month: 'short' });
const heroMonthEs = weekDateObj.toLocaleDateString('es-US', { month: 'short' });
const heroDay = weekDateObj.getDate();

// Flag helper
function getFlag(classroom: string): { isImg: boolean; src?: string; emoji?: string } {
  const flag = config.classroomFlags[classroom as keyof typeof config.classroomFlags];
  if (flag?.startsWith('img:')) {
    return { isImg: true, src: `${base}/${flag.slice(4)}` };
  }
  return { isImg: false, emoji: flag };
}

// Books conditional
const hasBooks = weekData.books && weekData.books.length > 0;
const hasAsk = weekData.askYourChild && weekData.askYourChild.length > 0;
const hasVocab = weekData.vocabulary && weekData.vocabulary.en && weekData.vocabulary.en.length > 0;
const hasRoars = roarsCount > 0;

// Ask count
const askCount = weekData.askYourChild?.length || 0;

// Week N/total for header
const weekNum = progress.weekNumber;
const weekTotal = progress.totalWeeks;
---

<div class="pk-app">

  <!-- ===== STICKY HEADER ===== -->
  <header class="pk-sticky">
    <div class="pk-sticky-row">
      <div class="pk-seal">
        {logo && <img src={`${base}/${logo}`} alt="Bancroft" />}
      </div>
      <div class="pk-sticky-text">
        <div class="pk-ttl display">
          <span data-en="1st Grade · Bancroft" data-es="1er Grado · Bancroft">1st Grade · Bancroft</span>
        </div>
        <div class="pk-sub">
          <span
            data-en={`Week of ${formattedDateEn} · Week ${weekNum}/${weekTotal}`}
            data-es={`Semana del ${formattedDateEs} · ${weekNum}/${weekTotal}`}
          >Week of {formattedDateEn} · Week {weekNum}/{weekTotal}</span>
        </div>
      </div>
      <div class="pk-lang-pill">
        <button class="lang-btn" data-set-lang="en">EN</button>
        <button class="lang-btn" data-set-lang="es">ES</button>
      </div>
    </div>
    <div class="pk-prog-strip">
      <div class="pk-prog-label">
        <strong id="pk-days-elapsed">{progress.elapsedSchoolDays}</strong>
        <span data-en={` of ${progress.totalSchoolDays}`} data-es={` de ${progress.totalSchoolDays}`}> of {progress.totalSchoolDays}</span>
      </div>
      <div class="pk-prog-track">
        <div class="pk-prog-fill" id="pk-prog-fill" style={`width: ${progress.percent}%`}></div>
      </div>
      <div class="pk-prog-label">
        <strong id="pk-days-remaining">{progress.remaining}</strong>
        <span data-en=" left" data-es=" restan"> left</span>
      </div>
    </div>
  </header>

  <!-- ===== ADD TO HOME SCREEN PROMPT ===== -->
  <div class="pk-ath" id="pk-ath">
    <div class="pk-ath-ico">📲</div>
    <div class="pk-ath-body">
      <span
        data-en={'<strong>Add to Home Screen</strong> for one-tap access every Monday.'}
        data-es={'<strong>Añadir a la pantalla de inicio</strong> para acceso fácil cada lunes.'}>
        <strong>Add to Home Screen</strong> for one-tap access every Monday.
      </span>
    </div>
    <button class="pk-ath-x" id="pk-ath-dismiss" aria-label="Dismiss">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- ===== HERO TODAY ===== -->
  <section class="pk-hero">
    <div class="pk-hero-kicker">
      <span data-en="Today · Monday" data-es="Hoy · Lunes" id="pk-hero-kicker-text">Today · Monday</span>
    </div>
    <div class="pk-hero-date display">
      <em id="pk-hero-month">{heroMonthEn}</em>&nbsp;<span id="pk-hero-day">{heroDay}</span>
    </div>
    <div class="pk-hero-weather" id="pk-hero-weather">
      <span data-en="Dismissal 3:15 pm" data-es="Salida 3:15 pm">Dismissal 3:15 pm</span>
    </div>
    <div class="pk-hero-stats">
      <div class="pk-hero-chip">
        <div class="pk-chip-lbl">
          <span data-en="Today's Special" data-es="Especial Hoy">Today's Special</span>
        </div>
        <div class="pk-chip-val" id="pk-today-special">
          {/* Neutral fallback: just "Day F". Filled with the real subject by JS once
              the user picks their classroom (otherwise this would mislead parents). */}
          <span class="pk-chip-e">📅</span>
          <span data-en={`Day ${specials['monday']}`} data-es={`Día ${specials['monday']}`}>
            Day {specials['monday']}
          </span>
        </div>
      </div>
      <div class="pk-hero-chip">
        <div class="pk-chip-lbl">
          <span data-en="Up Next" data-es="Próximo">Up Next</span>
        </div>
        <div class="pk-chip-val" id="pk-up-next">
          <!-- filled by JS from reminders -->
          {upNextReminder && upNextRD ? (
            <Fragment>
              <span class="pk-chip-e">📌</span>
              <span
                data-en={`${upNextLabelEn} · ${upNextRD.month} ${upNextRD.day}`}
                data-es={`${upNextLabelEs} · ${upNextRD.monthEs} ${upNextRD.day}`}>
                {upNextLabelEn} · {upNextRD.month} {upNextRD.day}
              </span>
            </Fragment>
          ) : (
            <Fragment>
              <span class="pk-chip-e">📅</span>
              <span data-en="See reminders" data-es="Ver recordatorios">See reminders</span>
            </Fragment>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== STATUS BAR ===== -->
  {firstReminder && (
    <button class="pk-status-bar" id="pk-status-bar" aria-label="Go to reminders">
      <span class="pk-pulse"></span>
      <div class="pk-status-txt">
        <span data-en={statusTextEn} data-es={statusTextEs}>{statusTextEn}</span>
      </div>
      <svg class="pk-status-chev" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </button>
  )}

  <!-- ===== QUICK LINKS ===== -->
  <div class="pk-ql-row">
    {config.quickLinks.map(link => (
      <a class="pk-ql" href={link.url} target="_blank" rel="noopener">
        <span class="pk-ql-e">{link.icon}</span>
        <span data-en={link.en} data-es={link.es}>{link.en}</span>
      </a>
    ))}
  </div>

  <!-- ===== CARD STACK ===== -->
  <div class="pk-stack">

    <!-- REMINDERS -->
    {reminderCount > 0 && (
      <details class="pk-card pk-action" open id="pk-card-reminders">
        <summary class="pk-card-head">
          <div class="pk-card-icon">📌</div>
          <div class="pk-card-meta">
            <h3 class="pk-card-title">
              <span data-en="Reminders" data-es="Recordatorios">Reminders</span>
            </h3>
            <div class="pk-card-peek">
              <span data-en={reminderPeekEn || `${reminderCount} reminders`} data-es={reminderPeekEs || `${reminderCount} recordatorios`}>
                {reminderPeekEn || `${reminderCount} reminders`}
              </span>
            </div>
          </div>
          <div class="pk-card-trail">
            <span class="pk-card-badge">{reminderCount}</span>
            <svg class="pk-card-chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </div>
        </summary>
        <div class="pk-card-body">
          <ul class="pk-rem-list">
            {sortedReminders.map((reminder: any) => {
              const rd = parseReminderDate(reminder.date);
              const isNow = reminder.date === date;
              return (
                <li class={isNow ? 'pk-rem-now' : ''}>
                  <div class="pk-rem-badge">
                    <div class="pk-rem-m">
                      <span data-en={rd.month} data-es={rd.monthEs}>{rd.month}</span>
                    </div>
                    <div class="pk-rem-d">{rd.day}</div>
                  </div>
                  <div class="pk-rem-text">
                    <span data-en={reminder.en} data-es={reminder.es || reminder.en} set:html={reminder.en} />
                  </div>
                </li>
              );
            })}
          </ul>
        </div>
      </details>
    )}

    <!-- SPECIALS -->
    <details class="pk-card pk-specials" open id="pk-card-specials">
      <summary class="pk-card-head">
        <div class="pk-card-icon">🎨</div>
        <div class="pk-card-meta">
          <h3 class="pk-card-title">
            <span data-en="Specials" data-es="Especiales">Specials</span>
          </h3>
          <div class="pk-card-peek" id="pk-specials-peek">
            <span data-en="Tap your child's class" data-es="Toca el salón de tu hijo/a">Tap your child's class</span>
          </div>
        </div>
        <div class="pk-card-trail">
          <span class="pk-card-badge" id="pk-specials-badge" hidden></span>
          <svg class="pk-card-chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </div>
      </summary>
      <div class="pk-card-body">
        <!-- Room tabs -->
        <div class="pk-room-tabs" role="tablist" aria-label="Classroom">
          {config.classrooms.map(classroom => {
            const fl = getFlag(classroom);
            return (
              <button
                class="pk-room-tab"
                data-classroom={classroom}
                role="tab"
                aria-selected="false"
              >
                {fl.isImg
                  ? <img src={fl.src} alt="" width="14" height="10" />
                  : <span>{fl.emoji}</span>
                }
                {classroom}
              </button>
            );
          })}
        </div>
        <!-- 5-day specials mini grid. Renders with just day letters + a "Day X" hint;
             JS fills in icons/subjects once the family picks their classroom above. -->
        <div class="pk-spec-row" id="pk-spec-grid">
          {dayKeys.map((day, i) => {
            const letter = specials[day];
            return (
              <div class="pk-spec-cell" data-day-index={i}>
                <div class="pk-spec-d">
                  <span data-en={dayShortEn[i]} data-es={dayShortEs[i]}>{dayShortEn[i]}</span>
                </div>
                <div class="pk-spec-e" data-subject-icon>📅</div>
                <div class="pk-spec-s">
                  <span data-en={`Day ${letter}`} data-es={`Día ${letter}`} data-subject-label>Day {letter}</span>
                </div>
                <div class="pk-spec-l" data-letter-label>{letter}</div>
              </div>
            );
          })}
        </div>
        <!-- Full grid (all 6 classrooms) -->
        <div class="pk-full-mini">
          <span data-en="Compare all 6 classrooms · " data-es="Comparar los 6 salones · ">Compare all 6 classrooms · </span>
          <a href="#pk-full-table-section" id="pk-full-grid-toggle" aria-expanded="false">
            <span data-en="Open full grid" data-es="Abrir cuadrícula">Open full grid</span>
          </a>
        </div>
        <!-- Full grid table (initially hidden) -->
        <div id="pk-full-table-section" class="pk-full-table-wrap" hidden aria-hidden="true">
          <div style="overflow-x: auto; margin-top: 12px;">
            <table class="pk-full-table">
              <thead>
                <tr>
                  <th></th>
                  {dayKeys.map((day, i) => (
                    <th>
                      <span data-en={dayAbbrevEn[i]} data-es={dayAbbrevEs[i]}>{dayAbbrevEn[i]}</span>
                      <br /><small>Day {specials[day]}</small>
                    </th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {config.classrooms.map(classroom => (
                  <tr>
                    <td class="pk-ft-room">{classroom}</td>
                    {dayKeys.map(day => {
                      const letter = specials[day];
                      const subject = getSpecialForDay(classroom, letter);
                      const icon = getSubjectIcon(subject);
                      const trans = getSubjectTranslation(subject);
                      return (
                        <td class="pk-ft-cell">
                          <span style="font-size: 1rem;">{icon}</span>
                          <br />
                          <small data-en={subject} data-es={trans}>{subject}</small>
                        </td>
                      );
                    })}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </details>

    <!-- WELCOME -->
    <details class="pk-card pk-welcome">
      <summary class="pk-card-head">
        <div class="pk-card-icon">👋</div>
        <div class="pk-card-meta">
          <h3 class="pk-card-title">
            <span data-en="From the Teacher" data-es="De la Maestra">From the Teacher</span>
          </h3>
          <div class="pk-card-peek">
            <span
              data-en={weekData.welcome.en.replace(/<[^>]+>/g, '').slice(0, 80)}
              data-es={weekData.welcome.es.replace(/<[^>]+>/g, '').slice(0, 80)}
            >
              {weekData.welcome.en.replace(/<[^>]+>/g, '').slice(0, 80)}
            </span>
          </div>
        </div>
        <div class="pk-card-trail">
          <svg class="pk-card-chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </div>
      </summary>
      <div class="pk-card-body pk-prose">
        <div data-lang-en set:html={`<p>${textToHTML(weekData.welcome.en)}</p>`} />
        <div data-lang-es style="display:none" set:html={`<p>${textToHTML(weekData.welcome.es)}</p>`} />
      </div>
    </details>

    <!-- MATH -->
    <details class="pk-card pk-math">
      <summary class="pk-card-head">
        <div class="pk-card-icon">🔢</div>
        <div class="pk-card-meta">
          <h3 class="pk-card-title">
            <span data-en="Math" data-es="Matemáticas">Math</span>
          </h3>
          <div class="pk-card-peek">
            <span
              data-en={weekData.math.en.replace(/<[^>]+>/g, '').slice(0, 80)}
              data-es={weekData.math.es.replace(/<[^>]+>/g, '').slice(0, 80)}
            >
              {weekData.math.en.replace(/<[^>]+>/g, '').slice(0, 80)}
            </span>
          </div>
        </div>
        <div class="pk-card-trail">
          <svg class="pk-card-chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </div>
      </summary>
      <div class="pk-card-body pk-prose">
        <div data-lang-en set:html={`<p>${textToHTML(weekData.math.en)}</p>`} />
        <div data-lang-es style="display:none" set:html={`<p>${textToHTML(weekData.math.es)}</p>`} />
      </div>
    </details>

    <!-- LITERACY -->
    <details class="pk-card pk-lit">
      <summary class="pk-card-head">
        <div class="pk-card-icon">📖</div>
        <div class="pk-card-meta">
          <h3 class="pk-card-title">
            <span data-en="Literacy" data-es="Lectura">Literacy</span>
          </h3>
          <div class="pk-card-peek">
            <span
              data-en={weekData.literacy.en.replace(/<[^>]+>/g, '').slice(0, 80)}
              data-es={weekData.literacy.es.replace(/<[^>]+>/g, '').slice(0, 80)}
            >
              {weekData.literacy.en.replace(/<[^>]+>/g, '').slice(0, 80)}
            </span>
          </div>
        </div>
        <div class="pk-card-trail">
          <svg class="pk-card-chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </div>
      </summary>
      <div class="pk-card-body pk-prose">
        <div data-lang-en set:html={`<p>${textToHTML(weekData.literacy.en)}</p>`} />
        <div data-lang-es style="display:none" set:html={`<p>${textToHTML(weekData.literacy.es)}</p>`} />
      </div>
    </details>

    <!-- ASK YOUR CHILD -->
    {hasAsk && (
      <details class="pk-card pk-ask">
        <summary class="pk-card-head">
          <div class="pk-card-icon">💬</div>
          <div class="pk-card-meta">
            <h3 class="pk-card-title">
              <span data-en="Ask Your Child" data-es="Pregúntale">Ask Your Child</span>
            </h3>
            <div class="pk-card-peek">
              <span
                data-en={`${askCount} conversation starters for tonight`}
                data-es={`${askCount} preguntas para esta noche`}
              >
                {askCount} conversation starters for tonight
              </span>
            </div>
          </div>
          <div class="pk-card-trail">
            <span class="pk-card-badge">{askCount}</span>
            <svg class="pk-card-chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </div>
        </summary>
        <div class="pk-card-body">
          <ul class="pk-ask-bubbles">
            {weekData.askYourChild.map((item: any) => (
              <li data-en={item.en} data-es={item.es}>{item.en}</li>
            ))}
          </ul>
        </div>
      </details>
    )}

    <!-- VOCABULARY -->
    {hasVocab && (
      <details class="pk-card pk-vocab">
        <summary class="pk-card-head">
          <div class="pk-card-icon">📝</div>
          <div class="pk-card-meta">
            <h3 class="pk-card-title">
              <span data-en="Words of the Week" data-es="Palabras">Words of the Week</span>
            </h3>
            <div class="pk-card-peek">
              <span
                data-en={`${vocabCount} words · tap to flip EN ⇄ ES`}
                data-es={`${vocabCount} palabras · toca para girar`}
              >
                {vocabCount} words · tap to flip EN ⇄ ES
              </span>
            </div>
          </div>
          <div class="pk-card-trail">
            <span class="pk-card-badge">{vocabCount}</span>
            <svg class="pk-card-chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </div>
        </summary>
        <div class="pk-card-body">
          {isVocabGrouped ? (
            (weekData.vocabulary.en as any[]).map((enGroup: any, gi: number) => {
              const esGroup = (weekData.vocabulary.es as any[])[gi];
              const frontLang = enGroup.frontLang || esGroup?.frontLang;
              // front face: ES if frontLang='es', else EN
              const frontGroup = frontLang === 'es' ? esGroup : enGroup;
              const backGroup = frontLang === 'es' ? enGroup : esGroup;
              return (
                <div class="pk-vocab-group">
                  <div class="pk-vg-label">
                    <span data-en={enGroup.label} data-es={esGroup?.label || enGroup.label}>{enGroup.label}</span>
                  </div>
                  <div class="pk-vg-pills">
                    {frontGroup.words.map((word: string, wi: number) => (
                      <span
                        class="pk-vp"
                        data-en-word={frontLang === 'es' ? backGroup?.words?.[wi] || word : word}
                        data-es-word={frontLang === 'es' ? word : backGroup?.words?.[wi] || word}
                        data-front-lang={frontLang || ''}
                      >
                        {word}
                      </span>
                    ))}
                  </div>
                </div>
              );
            })
          ) : (
            <div class="pk-vocab-group">
              <div class="pk-vg-pills">
                {(weekData.vocabulary.en as string[]).map((word: string, i: number) => (
                  <span
                    class="pk-vp"
                    data-en-word={word}
                    data-es-word={(weekData.vocabulary.es as string[])[i] || word}
                    data-front-lang=""
                  >
                    {word}
                  </span>
                ))}
              </div>
            </div>
          )}
        </div>
      </details>
    )}

    <!-- BOOKS -->
    {hasBooks && (
      <details class="pk-card pk-books">
        <summary class="pk-card-head">
          <div class="pk-card-icon">📚</div>
          <div class="pk-card-meta">
            <h3 class="pk-card-title">
              <span data-en="Books &amp; Read-Alouds" data-es="Libros y Lectura">Books &amp; Read-Alouds</span>
            </h3>
            <div class="pk-card-peek">
              <span
                data-en={`${weekData.books.length} book${weekData.books.length !== 1 ? 's' : ''} this week`}
                data-es={`${weekData.books.length} libro${weekData.books.length !== 1 ? 's' : ''} esta semana`}
              >
                {weekData.books.length} book{weekData.books.length !== 1 ? 's' : ''} this week
              </span>
            </div>
          </div>
          <div class="pk-card-trail">
            <span class="pk-card-badge">{weekData.books.length}</span>
            <svg class="pk-card-chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </div>
        </summary>
        <div class="pk-card-body">
          <div class="pk-books-list">
            {weekData.books.map((book: any) => (
              <div class="pk-book-card">
                <span class="pk-book-ico">📕</span>
                <div>
                  <div class="pk-book-title" data-en={book.title.en} data-es={book.title.es}>{book.title.en}</div>
                  <div class="pk-book-author" data-en={`by ${book.author}`} data-es={`por ${book.author}`}>by {book.author}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </details>
    )}

    <!-- ROARS -->
    {hasRoars && (
      <details class="pk-card pk-roars" open>
        <summary class="pk-card-head">
          <div class="pk-card-icon">🐯</div>
          <div class="pk-card-meta">
            <h3 class="pk-card-title">ROARS</h3>
            <div class="pk-card-peek">
              <span
                data-en={`${roarsCount} shout-out${roarsCount !== 1 ? 's' : ''} this week`}
                data-es={`${roarsCount} reconocimiento${roarsCount !== 1 ? 's' : ''}`}
              >
                {roarsCount} shout-out{roarsCount !== 1 ? 's' : ''} this week
              </span>
            </div>
          </div>
          <div class="pk-card-trail">
            <span class="pk-card-badge">★ {roarsCount}</span>
            <svg class="pk-card-chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </div>
        </summary>
        <div class="pk-card-body">
          <p class="pk-roars-line">
            <span data-en="Congratulations to this week's character stars!" data-es="¡Felicitaciones a las estrellas de la semana!">
              Congratulations to this week's character stars!
            </span>
          </p>
          <div class="pk-roars-pocket">
            {config.classrooms.map(classroom => {
              const student = weekData.roars?.[classroom as keyof typeof weekData.roars];
              if (!student) return null;
              const fl = getFlag(classroom);
              return (
                <div class="pk-rp">
                  <div class="pk-rp-ribbon">
                    {fl.isImg
                      ? <img src={fl.src} alt={classroom} width="18" height="14" />
                      : <span>{fl.emoji}</span>
                    }
                  </div>
                  <div class="pk-rp-nm">{student}</div>
                  <div class="pk-rp-rm">{classroom}</div>
                </div>
              );
            })}
          </div>
        </div>
      </details>
    )}

  </div><!-- /pk-stack -->

  <!-- ===== FOOTER ===== -->
  <div class="pk-foot">
    <div class="pk-foot-dots">
      {allWeeks.map((w, i) => (
        <div class={`pk-foot-dot${w === currentDate ? ' pk-foot-dot-current' : ''}`}></div>
