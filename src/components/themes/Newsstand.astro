<!-- ========== INLINE SCRIPT ========== -->
<script define:vars={{
  weekDate: date,
  weekSpecials: specials,
  allClassrooms: config.classrooms,
  vocabTranslations: translationMap,
  remindersData: sortedReminders,
}}>
document.addEventListener('DOMContentLoaded', function () {

  // ---- 1. LANG BUTTON SYNC (in-theme buttons match layout's setLang) ----
  function updateNsLangBtns() {
    var lang = document.documentElement.getAttribute('data-lang') || 'en';
    document.querySelectorAll('.ns-lang .lang-btn').forEach(function(btn) {
      btn.classList.toggle('active', btn.dataset.setLang === lang);
    });
  }
  var langObserver = new MutationObserver(updateNsLangBtns);
  langObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-lang'] });
  updateNsLangBtns();

  // ---- 2. SPECIALS TABLE: highlight selected classroom row ----
  function highlightClassroomRow() {
    var saved = localStorage.getItem('nl-classroom') || allClassrooms[0];
    document.querySelectorAll('#ns-specials-tbody tr').forEach(function(row) {
      var isYou = row.getAttribute('data-classroom') === saved;
      row.classList.toggle('ns-you', isYou);
    });
  }
  highlightClassroomRow();
  // Re-highlight when classroom changes via global selectClassroom
  window.addEventListener('storage', function(e) {
    if (e.key === 'nl-classroom') highlightClassroomRow();
  });
  // Patch: observe classroom button clicks in this theme
  document.querySelectorAll('.classroom-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      setTimeout(highlightClassroomRow, 50);
    });
  });

  // ---- 3. AT-A-GLANCE: Today pane — compute real letter day ----
  var dayKeyMap = ['sunday','monday','tuesday','wednesday','thursday','friday','saturday'];
  var dayShortEn = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  var dayShortEs = ['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];
  function getWeekBounds() {
    var parts = weekDate.split('-').map(Number);
    var mon = new Date(parts[0], parts[1]-1, parts[2]);
    // weekDate is always Monday
    var fri = new Date(mon); fri.setDate(fri.getDate() + 4);
    return { mon: mon, fri: fri };
  }
  function updateTodayPane() {
    var bounds = getWeekBounds();
    var now = new Date();
    now.setHours(0,0,0,0);
    if (now >= bounds.mon && now <= bounds.fri) {
      var dow = now.getDay(); // 1=Mon … 5=Fri
      var keys = ['monday','tuesday','wednesday','thursday','friday'];
      var dayIdx = dow - 1; // 0-based
      var letter = weekSpecials[keys[dayIdx]] || '?';
      var todayEl = document.getElementById('ns-today-val');
      if (todayEl) {
        var lang = document.documentElement.getAttribute('data-lang') || 'en';
        // Render as a [data-en/data-es]-tagged span so the layout's setLang
        // can swap correctly when the user toggles language afterward.
        var visible = lang === 'es' ? ('Día ' + letter) : ('Day ' + letter);
        todayEl.innerHTML =
          '<span data-en="Day ' + letter + '" data-es="Día ' + letter + '">' + visible + '</span>';
      }
    }
  }
  updateTodayPane();
  langObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-lang'] });

  // ---- 4. AT-A-GLANCE: Up Next pane — first reminder after today ----
  function updateUpNext() {
    var today = new Date();
    today.setHours(0,0,0,0);
    var todayISO = today.toISOString().split('T')[0];
    var future = remindersData.filter(function(r) { return r.date > todayISO; });
    if (!future.length) return;
    var next = future[0];
    var valEl = document.getElementById('ns-upnext-val');
    var metaEl = document.getElementById('ns-upnext-meta');
    if (!valEl || !metaEl) return;
    var lang = document.documentElement.getAttribute('data-lang') || 'en';
    var txt = (lang === 'es' ? next.es : next.en).replace(/<[^>]+>/g,'');
    var shortTitle = txt.split('.')[0].replace(/\s*—.*$/,'').trim();
    if (shortTitle.length > 40) shortTitle = shortTitle.substring(0,38) + '…';
    valEl.textContent = shortTitle;
    // Date meta
    var d = new Date(next.date + 'T12:00:00');
    var dow = d.getDay();
    var dayEn = dayShortEn[dow];
    var dayEs = dayShortEs[dow];
    var mon = d.toLocaleDateString('en-US', { month: 'short' });
    var monEs = d.toLocaleDateString('es-US', { month: 'short' });
    metaEl.textContent = lang === 'es'
      ? dayEs + ' ' + d.getDate() + ' ' + monEs
      : dayEn + ' ' + mon + ' ' + d.getDate();
  }
  updateUpNext();

  // ---- 5. WEATHER — Open-Meteo fetch ----
  (async function fetchWeather() {
    var parts = weekDate.split('-').map(Number);
    var weekStart = new Date(parts[0], parts[1]-1, parts[2]);
    var weekEnd = new Date(weekStart); weekEnd.setDate(weekEnd.getDate() + 4);
    var now = new Date();
    var diffDays = Math.abs((now.getTime() - weekStart.getTime()) / (1000*60*60*24));
    if (diffDays > 10) return;

    var lat = 38.9283, lon = -77.0365;
    var endISO = weekEnd.toISOString().split('T')[0];
    var weatherCodes = {
      0:'☀️',1:'🌤️',2:'⛅',3:'☁️',
      45:'🌫️',48:'🌫️',
      51:'🌦️',53:'🌧️',55:'🌧️',
      61:'🌧️',63:'🌧️',65:'🌧️',
      71:'🌨️',73:'🌨️',75:'🌨️',
      80:'🌦️',81:'🌧️',82:'🌧️',
      95:'⛈️',96:'⛈️',99:'⛈️',
    };
    try {
      var url = 'https://api.open-meteo.com/v1/forecast?latitude=' + lat
        + '&longitude=' + lon
        + '&daily=temperature_2m_max,temperature_2m_min,precipitation_probability_max,weathercode'
        + '&temperature_unit=fahrenheit&timezone=America/New_York'
        + '&start_date=' + weekDate + '&end_date=' + endISO;
      var resp = await fetch(url);
      if (!resp.ok) return;
      var data = await resp.json();
      var daily = data.daily;
      if (!daily || !daily.time) return;

      // Fill today's weather slot in pane 2
      var nowDate = new Date(); nowDate.setHours(0,0,0,0);
      var nowISO = nowDate.toISOString().split('T')[0];
      var todayIdx = daily.time.indexOf(nowISO);
      if (todayIdx === -1) todayIdx = 0; // fallback to Monday

      var high = Math.round(daily.temperature_2m_max[todayIdx]);
      var code = daily.weathercode[todayIdx];
      var icon = weatherCodes[code] || '🌡️';
      var lang = document.documentElement.getAttribute('data-lang') || 'en';
      var slot = document.getElementById('ns-weather-slot');
      if (slot) {
        if (lang === 'es') {
          var highC = Math.round((high - 32) * 5/9);
          slot.textContent = highC + '°C ' + icon;
        } else {
          slot.textContent = high + '°F ' + icon;
        }
      }
    } catch(e) { /* weather is non-critical */ }
  })();

  // ---- 6. VOCAB WORD TAP — click to toggle translation ----
  document.querySelectorAll('.ns-vg-words span').forEach(function(span) {
    var front = span.getAttribute('data-front') || span.textContent;
    var back = span.getAttribute('data-back') || '';
    if (!back || back === front) return;
    span.style.cursor = 'pointer';
    span.addEventListener('click', function() {
      var flipped = span.getAttribute('data-flipped') === '1';
      span.textContent = flipped ? front : back;
      span.style.color = flipped ? '' : 'var(--ns-purple)';
      span.style.fontStyle = flipped ? 'italic' : 'normal';
      span.setAttribute('data-flipped', flipped ? '0' : '1');
    });
  });

});
</script>

