---
import config from '../../data/config.json';
import {
  textToHTML, formatDate,
  getSubjectIcon, getSpecialForDay, getSubjectTranslation,
  getSchoolYearProgress,
} from '../../lib/utils';

interface Props {
  weekData: any;
  currentDate: string;
  allWeeks: string[];
  issueNumber: number;
}

const { weekData, issueNumber } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const date = weekData.date;

// School year progress
const progress = getSchoolYearProgress(date);

// Day letter keys
const dayKeys = ['monday', 'tuesday', 'wednesday', 'thursday', 'friday'] as const;
const specials = weekData.specials as Record<string, string>;

// Short subject labels used in the Specials Board cells.
// Hoisted here (not in the JSX expression) so the TS generic doesn't confuse the Astro parser.
const nsShortEn: Record<string, string> = { Music: 'Music', Science: 'Sci', PE: 'PE', Library: 'Lib', Art: 'Art' };
const nsShortEs: Record<string, string> = { Music: 'Mús',   Science: 'Cie', PE: 'EF', Library: 'Bib', Art: 'Arte' };

// Parse reminder date helper
function parseReminderDate(dateStr: string) {
  const d = new Date(dateStr + 'T12:00:00');
  const dayNum = d.getDate();
  const monthEn = d.toLocaleDateString('en-US', { month: 'short' }).toUpperCase();
  const monthEs = d.toLocaleDateString('es-US', { month: 'short' }).toUpperCase();
  const dayNameEn = d.toLocaleDateString('en-US', { weekday: 'short' }).toUpperCase();
  const dayNameEs = d.toLocaleDateString('es-US', { weekday: 'short' }).toUpperCase();
  return { dayNum, monthEn, monthEs, dayNameEn, dayNameEs };
}

// Sort reminders ascending
const sortedReminders = weekData.reminders
  ? [...weekData.reminders].sort((a: any, b: any) => a.date.localeCompare(b.date))
  : [];

// ROARS count and classrooms with ROARS this week
const roarsEntries = config.classrooms
  .map(c => ({ classroom: c, student: weekData.roars?.[c] }))
  .filter(e => e.student);
const roarsCount = roarsEntries.length;

// Pull quote: second sentence of welcome.en, fallback first
function pullQuote(text: string): string {
  // Strip HTML tags
  const plain = text.replace(/<[^>]+>/g, '');
  const sentences = plain.split(/\.\s+/);
  const raw = sentences.length > 1 ? sentences[1] : sentences[0];
  return raw.replace(/["""]/g, '').trim();
}
const pullEn = pullQuote(weekData.welcome.en);
const pullEs = pullQuote(weekData.welcome.es);

// Vocabulary: detect grouped vs flat
const vocabEn = weekData.vocabulary?.en || [];
const vocabEs = weekData.vocabulary?.es || [];
const isGrouped = vocabEn.length > 0 && typeof vocabEn[0] === 'object' && (vocabEn[0] as any).words;

// Build vocab groups for display + translation map for click-to-translate
interface VocabGroup {
  labelEn: string;
  labelEs: string;
  wordsEn: string[];
  wordsEs: string[];
  frontLang?: string;
}

let vocabGroups: VocabGroup[] = [];
if (isGrouped) {
  vocabGroups = (vocabEn as any[]).map((enGroup: any, gi: number) => {
    const esGroup = (vocabEs as any[])[gi] || { label: enGroup.label, words: [] };
    return {
      labelEn: enGroup.label,
      labelEs: esGroup.label,
      wordsEn: enGroup.words,
      wordsEs: esGroup.words,
      frontLang: enGroup.frontLang || esGroup.frontLang,
    };
  });
} else {
  vocabGroups = [{
    labelEn: 'Vocabulary',
    labelEs: 'Vocabulario',
    wordsEn: vocabEn as string[],
    wordsEs: vocabEs as string[],
    frontLang: undefined,
  }];
}

// Build translation map for client script: { word -> translation }
const translationMap: Record<string, string> = {};
for (const grp of vocabGroups) {
  grp.wordsEn.forEach((w: string, i: number) => {
    translationMap[w] = grp.wordsEs[i] || w;
    if (grp.wordsEs[i]) translationMap[grp.wordsEs[i]] = w;
  });
}

// Has books?
const hasBooks = weekData.books && weekData.books.length > 0;

// Testing pane: scan ALL reminders for the next testing-related one
const firstReminder = sortedReminders[0];
const testingRe = /i-ready|testing|assessment/i;
const firstTestingReminder = sortedReminders.find(r => testingRe.test(r.en));
const isTestingReminder = !!firstTestingReminder;

// Extract subject ("ELA", "Math", "SLA", "Matemáticas") from the testing reminder text
function extractTestSubject(text: string): string {
  const m = text.match(/i-?ready\s+([A-Za-zÁÉÍÓÚáéíóú]+)/i);
  if (!m) return '';
  return m[1].trim();
}
const testingSubjectEn = firstTestingReminder ? extractTestSubject(firstTestingReminder.en) : '';
const testingSubjectEs = firstTestingReminder ? extractTestSubject(firstTestingReminder.es) : '';

// Contents sections — built dynamically
interface ContentItem {
  id: string;
  labelEn: string;
  labelEs: string;
}
const contentItems: ContentItem[] = [
  { id: 'cover', labelEn: 'ROARS · Cover Story', labelEs: 'ROARS · Portada' },
];
if (sortedReminders.length > 0) {
  contentItems.push({ id: 'action', labelEn: 'Datelines', labelEs: 'Fechas Importantes' });
}
contentItems.push(
  { id: 'welcome', labelEn: 'From the Teacher', labelEs: 'De la Maestra' },
  { id: 'specials', labelEn: 'Specials Board', labelEs: 'Especiales' },
  { id: 'math', labelEn: 'Mathematics', labelEs: 'Matemáticas' },
  { id: 'lit', labelEn: 'Literacy', labelEs: 'Lectura y Escritura' },
);
if (weekData.askYourChild && weekData.askYourChild.length > 0) {
  contentItems.push({ id: 'ask', labelEn: 'Ask Your Child', labelEs: 'Pregúntale' });
}
if (vocabEn.length > 0) {
  contentItems.push({ id: 'vocab', labelEn: 'Words of the Week', labelEs: 'Palabras de la Semana' });
}
if (hasBooks) {
  contentItems.push({ id: 'books', labelEn: 'Books & Read-Alouds', labelEs: 'Libros' });
}

// Specials week header: letter days for Mon-Fri
const dayLetters = dayKeys.map(d => specials[d] || '?');

// Formatted date
const dateEn = formatDate(date, 'en');
const dateEs = formatDate(date, 'es');

// Week specials kicker
const firstLetter = dayLetters[0];
const lastLetter = dayLetters[4];
const weekDateShort = (() => {
  const d = new Date(date + 'T12:00:00');
  return d.toLocaleDateString('en-US', { month: 'long', day: 'numeric' });
})();
const weekDateShortEs = (() => {
  const d = new Date(date + 'T12:00:00');
  return d.toLocaleDateString('es-US', { month: 'long', day: 'numeric' });
})();
---

<div class="ns-wrap">

  <!-- ========== MASTHEAD ========== -->
  <header class="ns-masthead">
    <div class="ns-masthead-top">
      <span><span data-en="Established 2025" data-es="Fundado 2025">Established 2025</span></span>
      <div class="ns-lang">
        <button class="lang-btn active" data-set-lang="en">EN</button>
        <button class="lang-btn" data-set-lang="es">ES</button>
      </div>
    </div>
    <p class="ns-masthead-title">
      <span data-en="The Bancroft" data-es="El Bancroft">The Bancroft</span>
    </p>
    <h1 class="ns-masthead-name">
      <span data-en="First Grade" data-es="Primer Grado">First Grade</span>
    </h1>
    <p class="ns-masthead-tag">
      <span data-en="A weekly classroom letter, in two languages, for the families of Bancroft Elementary School." data-es="Una carta semanal del aula, en dos idiomas, para las familias de la Escuela Primaria Bancroft.">A weekly classroom letter, in two languages, for the families of Bancroft Elementary School.</span>
    </p>
    <div class="ns-masthead-rule">
      <span class="ns-vol">Vol. I &middot; <span data-en="Issue" data-es="Número">Issue</span> {issueNumber}</span>
      <span>Washington, DC &middot; <span data-en={dateEn} data-es={dateEs}>{dateEn}</span></span>
    </div>
  </header>

  <!-- ========== IN THIS ISSUE ========== -->
  <nav class="ns-contents" aria-label="Contents">
    <h2><span data-en="In This Issue" data-es="En Esta Edición">In This Issue</span></h2>
    <ul class="ns-contents-list">
      {contentItems.map((item, idx) => (
        <li>
          <a href={`#ns-${item.id}`}>
            <span class="ns-no">{String(idx + 1).padStart(2, '0')}</span>
            <span class="ns-nm">
              <span data-en={item.labelEn} data-es={item.labelEs}>{item.labelEn}</span>
            </span>
            <span class="ns-dots"></span>
            <span class="ns-pg">p. {idx + 1}</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <!-- ========== AT A GLANCE ========== -->
  <div class={`ns-glance${isTestingReminder ? ' ns-glance-4' : ' ns-glance-3'}`}>
    <!-- Pane 1: Week -->
    <div class="ns-pane">
      <div class="ns-glance-lbl">
        <span data-en="Week" data-es="Semana">Week</span>
      </div>
      <div class="ns-glance-val">
        {progress.weekNumber} <em>/ {progress.totalWeeks}</em>
      </div>
      <div class="ns-glance-meta">
        <span data-lang-en>{progress.remaining} days remaining</span>
        <span data-lang-es style="display:none">{progress.remaining} días restantes</span>
      </div>
    </div>

    <!-- Pane 2: Today / Day Letter + Weather -->
    <div class="ns-pane">
      <div class="ns-glance-lbl">
        <span data-en="Today" data-es="Hoy">Today</span>
      </div>
      <div class="ns-glance-val" id="ns-today-val">
        <span data-en={`Day ${dayLetters[0]}`} data-es={`Día ${dayLetters[0]}`}>Day {dayLetters[0]}</span>
      </div>
      <div class="ns-glance-meta" id="ns-weather-slot"></div>
    </div>

    <!-- Pane 3: Up Next -->
    <div class="ns-pane">
      <div class="ns-glance-lbl">
        <span data-en="Up Next" data-es="Próximo">Up Next</span>
      </div>
      <div class="ns-glance-val" id="ns-upnext-val">
        <span data-en={sortedReminders.length > 0 ? sortedReminders[0].en.replace(/<[^>]+>/g, '').split('.')[0] : '—'} data-es={sortedReminders.length > 0 ? sortedReminders[0].es.replace(/<[^>]+>/g, '').split('.')[0] : '—'}>
          {sortedReminders.length > 0 ? sortedReminders[0].en.replace(/<[^>]+>/g, '').split('.')[0] : '—'}
        </span>
      </div>
      <div class="ns-glance-meta" id="ns-upnext-meta">
        {sortedReminders.length > 0 && (() => {
          const rd = parseReminderDate(sortedReminders[0].date);
          return (
            <span>
              <span data-en={`${rd.dayNameEn} ${rd.monthEn} ${rd.dayNum}`} data-es={`${rd.dayNameEs} ${rd.dayNum} ${rd.monthEs}`}>
                {rd.dayNameEn} {rd.monthEn} {rd.dayNum}
              </span>
            </span>
          );
        })()}
      </div>
    </div>

    <!-- Pane 4: Testing (only if testing reminder) -->
    {isTestingReminder && (
      <div class="ns-pane" id="ns-testing-pane">
        <div class="ns-glance-lbl">
          <span data-en="Testing" data-es="Evaluaciones">Testing</span>
        </div>
        <div class="ns-glance-val ns-testing-val">
          <span data-en="i-Ready" data-es="i-Ready">i-Ready</span>
        </div>
        <div class="ns-glance-meta">
          <span data-lang-en>This week{testingSubjectEn ? ` · ${testingSubjectEn}` : ''}</span>
          <span data-lang-es style="display:none">Esta semana{testingSubjectEs ? ` · ${testingSubjectEs}` : ''}</span>
        </div>
      </div>
    )}
  </div>

  <!-- ========== COVER STORY — ROARS ========== -->
  <section id="ns-cover" class="ns-cover-story">
    <div class="ns-kicker">
      <span data-en="This Week's Roars" data-es="Reconocimientos de la Semana">This Week's Roars</span>
    </div>
    <h2 data-lang-en>This Week's <em>ROARS</em></h2>
    <h2 data-lang-es style="display:none">Los <em>ROARS</em> de la Semana</h2>
    <p class="ns-lede" data-lang-en>Congratulations to this week's 1st grade ROAR winners!</p>
    <p class="ns-lede" data-lang-es style="display:none">¡Felicitaciones a los ganadores ROAR de primer grado de esta semana!</p>

    <div class="ns-honor-roll">
      {roarsEntries.map(({ classroom, student }) => {
        const flag = config.classroomFlags[classroom as keyof typeof config.classroomFlags];
        const isImg = flag?.startsWith('img:');
        return (
          <div class="ns-honor-row">
            <div class="ns-flag">
              {isImg
                ? <img src={`${base}/${flag.slice(4)}`} alt={classroom} />
                : <span>{flag}</span>
              }
            </div>
            <div>
              <div class="ns-room">{classroom}</div>
              <div class="ns-honor-name">{student}</div>
            </div>
            <div class="ns-micro">&#9733;</div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- ========== No. 02 — ACTION / DATELINES ========== -->
  {sortedReminders.length > 0 && (
    <section id="ns-action" class="ns-s-action">
      <header class="ns-section-head">
        <div class="ns-section-no">02</div>
        <div style="flex:1">
          <h2 class="ns-section-title">
            <span data-en="Datelines" data-es="Fechas Importantes">Datelines</span>
          </h2>
          <div class="ns-section-kicker">
            <span data-en="What to put on the fridge." data-es="Qué poner en el refrigerador.">What to put on the fridge.</span>
          </div>
        </div>
      </header>
      <ul class="ns-datelines">
        {sortedReminders.map((reminder: any, i: number) => {
          const rd = parseReminderDate(reminder.date);
          const isFirst = i === 0;
          return (
            <li>
              <div class="ns-when">
                <span data-en={rd.dayNameEn} data-es={rd.dayNameEs}>{rd.dayNameEn}</span>
                <span class="ns-when-day">{rd.dayNum}</span>
              </div>
              <div class="ns-what">
                {isFirst
                  ? <span class="ns-tag"><span data-en="This Week" data-es="Esta Semana">This Week</span></span>
                  : <span class="ns-tag ns-tag-soft"><span data-en="Coming Up" data-es="Próximo">Coming Up</span></span>
                }
                <span data-lang-en set:html={reminder.en} />
                <span data-lang-es style="display:none" set:html={reminder.es} />
              </div>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  <!-- ========== No. 03 — WELCOME ========== -->
  <section id="ns-welcome" class="ns-s-welcome">
    <header class="ns-section-head">
      <div class="ns-section-no">{sortedReminders.length > 0 ? '03' : '02'}</div>
      <div style="flex:1">
        <h2 class="ns-section-title">
          <span data-en="From the Teacher" data-es="De la Maestra">From the Teacher</span>
        </h2>
        <div class="ns-section-kicker">
          <span data-en="A note for this week." data-es="Una nota de esta semana.">A note for this week.</span>
        </div>
      </div>
    </header>
    <article>
      <div data-lang-en>
        <p set:html={textToHTML(weekData.welcome.en)} />
      </div>
      <div data-lang-es style="display:none">
        <p set:html={textToHTML(weekData.welcome.es)} />
      </div>

      <div class="ns-pull">
        <span data-lang-en>&ldquo;{pullEn}&rdquo;</span>
        <span data-lang-es style="display:none">&laquo;{pullEs}&raquo;</span>
        <span class="ns-pull-attr">
          <span data-en="From your teacher" data-es="De su maestra">From your teacher</span>
        </span>
      </div>
    </article>
  </section>

  <!-- ========== No. 04 — SPECIALS BOARD ========== -->
  <section id="ns-specials" class="ns-s-spec">
    <header class="ns-section-head">
      <div class="ns-section-no">{sortedReminders.length > 0 ? '04' : '03'}</div>
      <div style="flex:1">
        <h2 class="ns-section-title">
          <span data-en="The Specials Board" data-es="Tablero de Especiales">The Specials Board</span>
        </h2>
        <div class="ns-section-kicker">
          <span data-lang-en>Week of {weekDateShort} &middot; Days {firstLetter}&ndash;{lastLetter}</span>
          <span data-lang-es style="display:none">Semana del {weekDateShortEs} &middot; Días {firstLetter}&ndash;{lastLetter}</span>
        </div>
      </div>
    </header>
    <div class="ns-specials-board">
      <table>
        <thead>
          <tr>
            <th></th>
            {dayKeys.map((day, i) => (
              <th>
                <span data-en={['M','T','W','Th','F'][i]} data-es={['L','M','Mi','J','V'][i]}>{['M','T','W','Th','F'][i]}</span>
                <span class="ns-day-ltr">{specials[day] || '?'}</span>
              </th>
            ))}
          </tr>
        </thead>
        <tbody id="ns-specials-tbody">
          {config.classrooms.map((classroom) => {
            const flag = config.classroomFlags[classroom as keyof typeof config.classroomFlags];
            const isImg = flag?.startsWith('img:');
            return (
              <tr data-classroom={classroom}>
                <td class="ns-room-cell">
                  {isImg
                    ? <img src={`${base}/${flag.slice(4)}`} alt={classroom} />
                    : <span>{flag}</span>
                  }
                  {classroom}
                </td>
                {dayKeys.map((day) => {
                  const letter = specials[day];
                  const subject = getSpecialForDay(classroom, letter);
                  const icon = getSubjectIcon(subject);
                  // Short labels for the table so all 5 columns fit at phone width.
                  const en = nsShortEn[subject] || subject;
                  const es = nsShortEs[subject] || subject;
                  return (
                    <td>
                      <span class="ns-ico">{icon}</span>
                      <span class="ns-nm" data-en={en} data-es={es}>{en}</span>
                    </td>
                  );
                })}
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
    <p class="ns-specials-hint">
      <span data-lang-en>&#9658; Highlighted row is your selected classroom.</span>
      <span data-lang-es style="display:none">&#9658; La fila resaltada es tu salón seleccionado.</span>
    </p>
  </section>

  <!-- ========== No. 05 — MATH ========== -->
  <section id="ns-math" class="ns-s-math">
    <header class="ns-section-head">
      <div class="ns-section-no">{sortedReminders.length > 0 ? '05' : '04'}</div>
      <div style="flex:1">
        <h2 class="ns-section-title">
          <span data-en="Mathematics" data-es="Matemáticas">Mathematics</span>
        </h2>
        <div class="ns-section-kicker">
          <span data-en="What we're learning this week." data-es="Lo que aprendemos esta semana.">What we're learning this week.</span>
        </div>
      </div>
    </header>
    <article>
      <div data-lang-en>
        <p set:html={textToHTML(weekData.math.en)} />
      </div>
      <div data-lang-es style="display:none">
        <p set:html={textToHTML(weekData.math.es)} />
      </div>
    </article>
  </section>

  <!-- ========== No. 06 — LITERACY ========== -->
  <section id="ns-lit" class="ns-s-lit">
    <header class="ns-section-head">
      <div class="ns-section-no">{sortedReminders.length > 0 ? '06' : '05'}</div>
      <div style="flex:1">
        <h2 class="ns-section-title">
          <span data-en="Literacy" data-es="Lectura y Escritura">Literacy</span>
        </h2>
        <div class="ns-section-kicker">
          <span data-en="Reading & writing news." data-es="Noticias de lectura y escritura.">Reading &amp; writing news.</span>
        </div>
      </div>
    </header>
    <article>
      <div data-lang-en>
        <p set:html={textToHTML(weekData.literacy.en)} />
      </div>
      <div data-lang-es style="display:none">
        <p set:html={textToHTML(weekData.literacy.es)} />
      </div>
    </article>
  </section>

  <!-- ========== No. 07 — ASK YOUR CHILD ========== -->
  {weekData.askYourChild && weekData.askYourChild.length > 0 && (
    <section id="ns-ask" class="ns-s-ask">
      <header class="ns-section-head">
        <div class="ns-section-no">{sortedReminders.length > 0 ? '07' : '06'}</div>
        <div style="flex:1">
          <h2 class="ns-section-title">
            <span data-en="Ask Your Child" data-es="Pregúntale">Ask Your Child</span>
          </h2>
          <div class="ns-section-kicker">
            <span data-en="Three openers for the dinner table." data-es="Tres iniciadores para la cena.">Three openers for the dinner table.</span>
          </div>
        </div>
      </header>
      <ol class="ns-ask-stack">
        {weekData.askYourChild.map((item: any) => (
          <li>
            <div class="ns-q">
              <span data-lang-en>{item.en}</span>
              <span data-lang-es style="display:none">{item.es}</span>
            </div>
          </li>
        ))}
      </ol>
    </section>
  )}

  <!-- ========== No. 08 — VOCABULARY POSTER ========== -->
  {vocabEn.length > 0 && (
    <section id="ns-vocab" class="ns-s-vocab">
      <header class="ns-section-head">
        <div class="ns-section-no">
          {(() => {
            let n = sortedReminders.length > 0 ? 7 : 6;
            if (!(weekData.askYourChild && weekData.askYourChild.length > 0)) n--;
            return String(n + (weekData.askYourChild && weekData.askYourChild.length > 0 ? 1 : 0)).padStart(2,'0');
          })()}
        </div>
        <div style="flex:1">
          <h2 class="ns-section-title">
            <span data-en="Words of the Week" data-es="Palabras de la Semana">Words of the Week</span>
          </h2>
          <div class="ns-section-kicker">
            <span data-en="Tap any word to translate." data-es="Toca cualquier palabra para traducir.">Tap any word to translate.</span>
          </div>
        </div>
      </header>
      <div class="ns-vocab-poster">
        {vocabGroups.map((grp) => (
          <div class="ns-vocab-group">
            <div class="ns-vg-label">
              <span data-en={grp.labelEn} data-es={grp.labelEs}>{grp.labelEn}</span>
            </div>
            <div class="ns-vg-words">
              {(grp.frontLang === 'es' ? grp.wordsEs : grp.wordsEn).map((word: string, wi: number) => {
                const backWord = grp.frontLang === 'es' ? grp.wordsEn[wi] : grp.wordsEs[wi];
                return (
                  <span
                    data-front={word}
                    data-back={backWord || word}
                  >{word}</span>
                );
              })}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- ========== BOOKS ========== -->
  {hasBooks && (
    <section id="ns-books" class="ns-s-books">
      <header class="ns-section-head">
        <div class="ns-section-no">
          {String(contentItems.findIndex(c => c.id === 'books') + 1).padStart(2,'0')}
        </div>
        <div style="flex:1">
          <h2 class="ns-section-title">
            <span data-en="Books &amp; Read-Alouds" data-es="Libros y Lectura">Books &amp; Read-Alouds</span>
          </h2>
          <div class="ns-section-kicker">
