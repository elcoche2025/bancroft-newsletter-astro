        </div>
      </header>
      <div class="ns-books-row">
        {weekData.books.map((book: any) => (
          <div class="ns-book">
            <div class="ns-book-cover">&#128218;</div>
            <div class="ns-book-meta">
              <p class="ns-book-title">
                <span data-en={book.title?.en || book.title} data-es={book.title?.es || book.title}>
                  {book.title?.en || book.title}
                </span>
              </p>
              <p class="ns-book-author">
                <span data-en={`by ${book.author}`} data-es={`por ${book.author}`}>by {book.author}</span>
